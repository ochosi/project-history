#!/usr/bin/env python3
"""
Generate project history from git commits + GitHub/GitLab/Jira data

This tool analyzes git history and correlates it with GitHub PRs, GitLab MRs,
and Jira tickets to generate a comprehensive project history with narrative
documentation.

Features:
- Commit→PR/MR/Jira correlation
- Multi-platform support (GitHub, GitLab, Jira)
- Importance scoring
- Theme detection
- Resumable processing with state file
- Incremental timeline and narrative generation
"""

import argparse
import json
import os
import re
import sys
from collections import defaultdict
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Dict, List, Optional, Set, Tuple, Any

try:
    import subprocess
except ImportError:
    print("Error: subprocess module required", file=sys.stderr)
    sys.exit(1)


class StateManager:
    """Manages resumable state for history generation."""

    def __init__(self, state_file: Path):
        self.state_file = state_file
        self.state = self.load()

    def load(self) -> Dict[str, Any]:
        """Load state from file or return default."""
        if self.state_file.exists():
            with open(self.state_file, 'r') as f:
                return json.load(f)
        return {
            "version": "1.0",
            "last_updated": None,
            "phases_completed": [],
            "correlation_done": False,
            "timelines_generated": [],
            "narratives_written": [],
        }

    def save(self):
        """Save current state to file."""
        self.state["last_updated"] = datetime.now(timezone.utc).isoformat()
        self.state_file.parent.mkdir(parents=True, exist_ok=True)
        with open(self.state_file, 'w') as f:
            json.dump(self.state, f, indent=2)

    def mark_phase_complete(self, phase: str):
        """Mark a phase as completed."""
        if phase not in self.state["phases_completed"]:
            self.state["phases_completed"].append(phase)
        self.save()


def normalize_config(config: Dict) -> Dict:
    """
    Normalize configuration to a uniform multi-repo format.

    Converts single-repo configs (platforms.github/gitlab as objects) to the
    multi-repo format (repos array) for uniform processing.

    Returns:
        Dict with 'repos' list, 'platforms' (jira only), and 'output_dir'
    """
    if 'repos' in config:
        return config

    repos = []
    platforms = config.get('platforms', {})

    github = platforms.get('github', {})
    if github.get('enabled'):
        repos.append({
            'name': github['repo'],
            'local_path': '.',
            'platform': 'github',
            'owner': github['owner'],
            'repo': github['repo'],
        })

    gitlab = platforms.get('gitlab', {})
    if gitlab.get('enabled'):
        project_id = gitlab['project_id']
        repos.append({
            'name': project_id.split('/')[-1],
            'local_path': '.',
            'platform': 'gitlab',
            'project_id': project_id,
            'url': gitlab['url'],
        })

    return {
        'repos': repos,
        'platforms': {'jira': platforms.get('jira', {'enabled': False})},
        'output_dir': config.get('output_dir', './history'),
    }


class GitAnalyzer:
    """Analyzes git repository history."""

    def __init__(self, repo_path: Path, verbose: bool = False, repo_name: str = None):
        self.repo_path = repo_path
        self.verbose = verbose
        self.repo_name = repo_name

    def log(self, message: str):
        """Log message if verbose."""
        if self.verbose:
            print(message)

    def get_all_commits(self) -> List[Dict[str, Any]]:
        """Get all commits from git history."""
        label = f" ({self.repo_name})" if self.repo_name else ""
        self.log(f"Fetching all commits from git history{label}...")

        # Format: %H|%an|%ae|%at|%s|%b
        cmd = [
            'git', 'log', '--all', '--format=%H|%an|%ae|%at|%s|%b%x00',
            '--date=iso-strict'
        ]

        result = subprocess.run(
            cmd,
            cwd=self.repo_path,
            capture_output=True,
            text=True,
            check=True
        )

        commits = []
        for entry in result.stdout.split('\x00'):
            if not entry.strip():
                continue

            parts = entry.split('|', 5)
            if len(parts) < 5:
                continue

            sha, author, email, timestamp, subject = parts[:5]
            body = parts[5] if len(parts) > 5 else ""

            commit = {
                'sha': sha.strip(),
                'author': author.strip(),
                'email': email.strip(),
                'date': datetime.fromtimestamp(int(timestamp), tz=timezone.utc),
                'subject': subject.strip(),
                'body': body.strip(),
                'message': f"{subject.strip()}\n{body.strip()}".strip()
            }
            if self.repo_name:
                commit['repo'] = self.repo_name
            commits.append(commit)

        self.log(f"Found {len(commits)} commits{label}")
        return commits

    def get_commit_stats(self, sha: str) -> Dict[str, int]:
        """Get file change statistics for a commit."""
        cmd = ['git', 'show', '--stat', '--format=', sha]
        result = subprocess.run(
            cmd,
            cwd=self.repo_path,
            capture_output=True,
            text=True
        )

        # Parse stats
        lines = result.stdout.strip().split('\n')
        files_changed = 0
        insertions = 0
        deletions = 0

        for line in lines:
            if 'file' in line and 'changed' in line:
                match = re.search(r'(\d+) file', line)
                if match:
                    files_changed = int(match.group(1))
                match = re.search(r'(\d+) insertion', line)
                if match:
                    insertions = int(match.group(1))
                match = re.search(r'(\d+) deletion', line)
                if match:
                    deletions = int(match.group(1))

        return {
            'files_changed': files_changed,
            'insertions': insertions,
            'deletions': deletions
        }


class IssueCorrelator:
    """Correlates git commits with GitHub PRs, GitLab MRs, and Jira tickets."""

    # GitHub PR patterns
    GITHUB_PR_PATTERNS = [
        r'\(#(\d+)\)',           # (#123)
        r'#(\d+)',               # #123
        r'fixes #(\d+)',         # fixes #123
        r'closes #(\d+)',        # closes #123
        r'merge pull request #(\d+)',  # merge pull request #123
    ]

    # GitLab MR patterns
    GITLAB_MR_PATTERNS = [
        r'\(!(\d+)\)',           # (!123)
        r'!(\d+)',               # !123
        r'fixes !(\d+)',         # fixes !123
        r'closes !(\d+)',        # closes !123
        r'merge request !(\d+)', # merge request !123
    ]

    # Jira ticket patterns (matches PROJ-123, ABC-456, etc.)
    JIRA_PATTERNS = [
        r'\b([A-Z][A-Z0-9]+-\d+)\b',  # PROJ-123, ABC-456
    ]

    def __init__(self, history_path: Path, verbose: bool = False,
                 repo_data_paths: Optional[Dict[str, Path]] = None):
        """
        Initialize the correlator.

        Args:
            history_path: Base history directory (used for Jira and single-repo data)
            verbose: Enable verbose logging
            repo_data_paths: For multi-repo, maps repo name → data directory.
                             When set, PR/MR data is loaded per-repo from these paths.
        """
        self.history_path = history_path
        self.verbose = verbose
        self.repo_data_paths = repo_data_paths

        if repo_data_paths:
            self._github_prs_by_repo = {}
            self._gitlab_mrs_by_repo = {}
            for repo_name, repo_path in repo_data_paths.items():
                self._github_prs_by_repo[repo_name] = self._load_github_prs_from(repo_path)
                self._gitlab_mrs_by_repo[repo_name] = self._load_gitlab_mrs_from(repo_path)
        else:
            self._github_prs_by_repo = None
            self._gitlab_mrs_by_repo = None

        self.github_prs = self._load_github_prs_from(history_path) if not repo_data_paths else {}
        self.gitlab_mrs = self._load_gitlab_mrs_from(history_path) if not repo_data_paths else {}
        self.jira_issues = self.load_jira_issues()

    def log(self, message: str):
        """Log message if verbose."""
        if self.verbose:
            print(message)

    def _load_github_prs_from(self, base_path: Path) -> Dict[int, Dict[str, Any]]:
        """Load GitHub PR metadata from markdown files under a base path."""
        self.log(f"Loading GitHub PR metadata from {base_path}...")
        prs = {}

        pr_dir = base_path / "pull-requests"
        if not pr_dir.exists():
            return prs

        for pr_file in pr_dir.rglob("*.md"):
            metadata = self._parse_markdown_metadata(pr_file)
            if metadata and metadata.get('type') == 'pull_request':
                pr_num = int(metadata.get('number', 0))
                if pr_num > 0:
                    prs[pr_num] = metadata

        self.log(f"Loaded {len(prs)} GitHub PRs")
        return prs

    def _load_gitlab_mrs_from(self, base_path: Path) -> Dict[int, Dict[str, Any]]:
        """Load GitLab MR metadata from markdown files under a base path."""
        self.log(f"Loading GitLab MR metadata from {base_path}...")
        mrs = {}

        mr_dir = base_path / "merge-requests"
        if not mr_dir.exists():
            return mrs

        for mr_file in mr_dir.rglob("*.md"):
            metadata = self._parse_markdown_metadata(mr_file)
            if metadata and metadata.get('type') == 'merge_request':
                mr_num = int(metadata.get('number', 0))
                if mr_num > 0:
                    mrs[mr_num] = metadata

        self.log(f"Loaded {len(mrs)} GitLab MRs")
        return mrs

    def get_github_prs(self, repo_name: Optional[str] = None) -> Dict[int, Dict[str, Any]]:
        """Get GitHub PRs, optionally filtered by repo name."""
        if repo_name and self._github_prs_by_repo:
            return self._github_prs_by_repo.get(repo_name, {})
        return self.github_prs

    def get_gitlab_mrs(self, repo_name: Optional[str] = None) -> Dict[int, Dict[str, Any]]:
        """Get GitLab MRs, optionally filtered by repo name."""
        if repo_name and self._gitlab_mrs_by_repo:
            return self._gitlab_mrs_by_repo.get(repo_name, {})
        return self.gitlab_mrs

    def all_github_prs(self) -> Dict[str, Dict[int, Dict[str, Any]]]:
        """Get all GitHub PRs across all repos. Returns {repo_name: {pr_num: data}}."""
        if self._github_prs_by_repo:
            return self._github_prs_by_repo
        return {None: self.github_prs}

    def all_gitlab_mrs(self) -> Dict[str, Dict[int, Dict[str, Any]]]:
        """Get all GitLab MRs across all repos. Returns {repo_name: {mr_num: data}}."""
        if self._gitlab_mrs_by_repo:
            return self._gitlab_mrs_by_repo
        return {None: self.gitlab_mrs}

    def load_jira_issues(self) -> Dict[str, Dict[str, Any]]:
        """Load all Jira issue metadata from markdown files."""
        self.log("Loading Jira issue metadata...")
        issues = {}

        jira_dir = self.history_path / "jira-issues"
        if not jira_dir.exists():
            return issues

        for issue_file in jira_dir.rglob("*.md"):
            metadata = self._parse_markdown_metadata(issue_file)
            if metadata and metadata.get('type') == 'jira_issue':
                key = metadata.get('key', '')
                if key:
                    issues[key] = metadata

        self.log(f"Loaded {len(issues)} Jira issues")
        return issues

    def _parse_markdown_metadata(self, file_path: Path) -> Optional[Dict[str, Any]]:
        """Parse metadata from markdown file frontmatter."""
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()

            # Extract frontmatter
            if not content.startswith('---'):
                return None

            parts = content.split('---', 2)
            if len(parts) < 3:
                return None

            # Parse frontmatter (simple YAML-like parsing)
            frontmatter = {}
            for line in parts[1].strip().split('\n'):
                if ':' in line:
                    key, value = line.split(':', 1)
                    key = key.strip()
                    value = value.strip()

                    # Remove quotes
                    if value.startswith('"') and value.endswith('"'):
                        value = value[1:-1]
                    elif value.startswith('[') and value.endswith(']'):
                        # Parse list
                        value = [v.strip().strip('"') for v in value[1:-1].split(',') if v.strip()]

                    frontmatter[key] = value

            frontmatter['body'] = parts[2].strip()
            frontmatter['file_path'] = str(file_path)
            return frontmatter

        except Exception as e:
            if self.verbose:
                print(f"Warning: Failed to parse {file_path}: {e}")
            return None

    def extract_references(self, message: str, repo_name: Optional[str] = None) -> Dict[str, Any]:
        """Extract all references (GitHub PRs, GitLab MRs, Jira tickets) from commit message."""
        refs = {
            'github_pr': None,
            'gitlab_mr': None,
            'jira_issues': []
        }

        github_prs = self.get_github_prs(repo_name)
        gitlab_mrs = self.get_gitlab_mrs(repo_name)

        # Extract GitHub PR
        for pattern in self.GITHUB_PR_PATTERNS:
            matches = re.findall(pattern, message, re.IGNORECASE)
            if matches and not refs['github_pr']:
                pr_num = int(matches[0])
                if pr_num in github_prs:
                    refs['github_pr'] = pr_num
                    break

        # Extract GitLab MR
        for pattern in self.GITLAB_MR_PATTERNS:
            matches = re.findall(pattern, message, re.IGNORECASE)
            if matches and not refs['gitlab_mr']:
                mr_num = int(matches[0])
                if mr_num in gitlab_mrs:
                    refs['gitlab_mr'] = mr_num
                    break

        # Extract Jira issues
        for pattern in self.JIRA_PATTERNS:
            matches = re.findall(pattern, message, re.IGNORECASE)
            for match in matches:
                if match in self.jira_issues:
                    refs['jira_issues'].append(match)

        return refs

    def correlate_commits(self, commits: List[Dict[str, Any]]) -> Dict[str, Dict[str, Any]]:
        """Build mapping of commit SHA → references (PRs, MRs, Jira tickets)."""
        self.log("Correlating commits to PRs, MRs, and Jira issues...")

        correlation = {}
        matched_github = 0
        matched_gitlab = 0
        matched_jira = 0

        for commit in commits:
            repo_name = commit.get('repo')
            refs = self.extract_references(commit['message'], repo_name=repo_name)

            # Only store if there are references
            if refs['github_pr'] or refs['gitlab_mr'] or refs['jira_issues']:
                if repo_name:
                    refs['repo'] = repo_name
                correlation[commit['sha']] = refs

                if refs['github_pr']:
                    matched_github += 1
                if refs['gitlab_mr']:
                    matched_gitlab += 1
                if refs['jira_issues']:
                    matched_jira += 1

        self.log(f"Matched {matched_github} commits to GitHub PRs")
        self.log(f"Matched {matched_gitlab} commits to GitLab MRs")
        self.log(f"Matched {matched_jira} commits to Jira issues")

        return correlation

    # Maintain backward compatibility
    @property
    def prs(self):
        """Backward compatibility: return GitHub PRs."""
        return self.github_prs


class ThemeDetector:
    """Detects themes and categorizes changes."""

    DEFAULT_THEMES = {
        'testing': {
            'keywords': ['test:', 'ci:', 'pytest', 'unittest', 'coverage', 'test'],
            'description': 'Testing and CI infrastructure'
        },
        'performance': {
            'keywords': ['perf', 'cache', 'optimization', 'speed', 'fast', 'parallel'],
            'description': 'Performance improvements'
        },
        'security': {
            'keywords': ['security', 'selinux', 'permission', 'capability'],
            'description': 'Security and permissions'
        },
        'documentation': {
            'keywords': ['docs:', 'documentation', 'readme', 'guide', 'manual'],
            'description': 'Documentation changes'
        },
        'api': {
            'keywords': ['api:', 'interface', 'cli', 'command'],
            'description': 'API and command-line interface'
        },
        'build': {
            'keywords': ['build', 'compile', 'makefile', 'cmake', 'configure'],
            'description': 'Build system changes'
        }
    }

    def __init__(self, themes: Optional[Dict[str, Dict[str, Any]]] = None):
        """
        Initialize the theme detector.

        Args:
            themes: Optional dictionary of theme definitions. If None, uses DEFAULT_THEMES.
                   Each theme should have 'keywords' and 'description' keys.
        """
        self.themes = themes if themes is not None else self.DEFAULT_THEMES

    def detect_themes(self, message: str) -> Set[str]:
        """Detect themes in a commit message."""
        msg_lower = message.lower()
        themes = set()

        for theme, config in self.themes.items():
            for keyword in config['keywords']:
                if keyword in msg_lower:
                    themes.add(theme)
                    break

        return themes


class ImportanceScorer:
    """Scores the importance of commits and PRs."""

    DEFAULT_ARCH_KEYWORDS = ['architecture', 'redesign', 'rewrite', 'migration', 'breaking']
    DEFAULT_TITLE_KEYWORDS = ['breaking', 'migration', 'redesign', 'rewrite', 'rfc']

    def __init__(self, verbose: bool = False,
                 architectural_keywords: Optional[List[str]] = None,
                 title_keywords: Optional[List[str]] = None):
        self.verbose = verbose
        self.architectural_keywords = architectural_keywords if architectural_keywords is not None else self.DEFAULT_ARCH_KEYWORDS
        self.title_keywords = title_keywords if title_keywords is not None else self.DEFAULT_TITLE_KEYWORDS

    def score_commit(self, commit: Dict[str, Any], pr_data: Optional[Dict[str, Any]] = None) -> int:
        """Score a commit's importance (0-100)."""
        score = 0

        # Message length factor (longer often means more significant)
        msg_len = len(commit['message'])
        if msg_len > 500:
            score += 5
        elif msg_len > 200:
            score += 3

        # Keywords indicating importance
        important_keywords = ['breaking', 'major', 'important', 'critical', 'fix', 'add']
        msg_lower = commit['message'].lower()
        for keyword in important_keywords:
            if keyword in msg_lower:
                score += 3

        # Architectural keywords
        for keyword in self.architectural_keywords:
            if keyword in msg_lower:
                score += 5

        # PR data bonus
        if pr_data:
            # PR description length
            body_len = len(pr_data.get('body', ''))
            if body_len > 2000:
                score += 10
            elif body_len > 1000:
                score += 5

            # Labels
            labels = pr_data.get('labels', [])
            if isinstance(labels, list):
                if 'breaking-change' in labels:
                    score += 15
                if 'enhancement' in labels:
                    score += 5
                if 'bug' in labels:
                    score += 3

        return min(score, 100)

    def score_pr(self, pr_data: Dict[str, Any]) -> int:
        """Score a PR's importance."""
        score = 0

        # Discussion length
        body_len = len(pr_data.get('body', ''))
        if body_len > 3000:
            score += 15
        elif body_len > 1500:
            score += 10
        elif body_len > 500:
            score += 5

        # Count discussion markers
        discussion_count = pr_data.get('body', '').count('###')
        score += min(discussion_count * 2, 10)

        # Labels
        labels = pr_data.get('labels', [])
        if isinstance(labels, list):
            if 'breaking-change' in labels:
                score += 20
            if 'enhancement' in labels:
                score += 10
            if 'design' in labels or 'architecture' in labels:
                score += 15

        # Title keywords
        title = pr_data.get('title', '').lower()
        if any(kw in title for kw in self.title_keywords):
            score += 10

        return min(score, 100)


class DiscoveryAnalyzer:
    """Analyzes git history to auto-discover themes, periods, and importance keywords."""

    NOISE_WORDS = {
        'fix', 'add', 'remove', 'update', 'merge', 'revert', 'bump', 'move',
        'rename', 'change', 'set', 'use', 'make', 'get', 'new', 'old',
        'the', 'and', 'for', 'from', 'with', 'this', 'that', 'not', 'but',
        'all', 'are', 'was', 'were', 'been', 'have', 'has', 'had', 'will',
        'can', 'may', 'should', 'would', 'could', 'does', 'did', 'into',
        'also', 'when', 'then', 'than', 'more', 'some', 'only', 'just',
        'now', 'here', 'there', 'where', 'which', 'what', 'how', 'who',
        'each', 'every', 'both', 'few', 'many', 'much', 'most', 'other',
        'about', 'after', 'before', 'between', 'over', 'under', 'again',
        'out', 'off', 'down', 'well', 'back', 'still', 'even', 'too',
        'bug', 'issue', 'patch', 'commit', 'branch', 'main', 'master',
        'head', 'base', 'pull', 'request', 'push', 'code', 'file', 'line',
        'src', 'lib', 'bin', 'var', 'tmp', 'etc', 'run', 'work', 'need',
        'see', 'try', 'let', 'put', 'take', 'give', 'keep', 'call',
        'instead', 'since', 'because', 'while', 'during', 'until', 'unless',
        'already', 'currently', 'properly', 'correctly', 'actually',
        'support', 'ensure', 'allow', 'avoid', 'handle', 'check', 'clean',
        'minor', 'small', 'simple', 'proper', 'correct', 'related',
        'using', 'added', 'fixed', 'updated', 'removed', 'changed',
        'don', 'doesn', 'didn', 'won', 'isn', 'aren', 'wasn', 'weren',
        'shouldn', 'couldn', 'wouldn',
    }

    def __init__(self, commits: List[Dict[str, Any]],
                 pr_data: Optional[Dict] = None,
                 mr_data: Optional[Dict] = None,
                 verbose: bool = False):
        self.commits = commits
        self.pr_data = pr_data or {}
        self.mr_data = mr_data or {}
        self.verbose = verbose

    def log(self, message: str):
        if self.verbose:
            print(message)

    def _tokenize(self, text: str) -> List[str]:
        """Tokenize text into lowercase words, filtering noise and short words."""
        words = re.findall(r'[a-z][a-z0-9_-]*[a-z0-9]|[a-z]', text.lower())
        return [w for w in words if w not in self.NOISE_WORDS and len(w) >= 3]

    def discover_themes(self, max_themes: int = 12) -> Dict[str, Dict[str, Any]]:
        """Discover themes from commit message keyword frequency and co-occurrence."""
        self.log("Analyzing commit messages for themes...")

        word_freq: Dict[str, int] = defaultdict(int)
        word_commits: Dict[str, Set[int]] = defaultdict(set)

        for i, commit in enumerate(self.commits):
            tokens = self._tokenize(commit['message'])
            seen = set()
            for token in tokens:
                if token not in seen:
                    word_freq[token] += 1
                    word_commits[token].add(i)
                    seen.add(token)

        if not word_freq:
            return {}

        min_count = max(3, len(self.commits) // 200)
        frequent = {w: c for w, c in word_freq.items() if c >= min_count}

        if not frequent:
            return {}

        ranked = sorted(frequent.items(), key=lambda x: -x[1])

        groups: List[Dict[str, Any]] = []
        used_words: Set[str] = set()

        for word, count in ranked:
            if word in used_words:
                continue

            group_words = [word]
            group_commits = word_commits[word].copy()
            used_words.add(word)

            for other_word, other_count in ranked:
                if other_word in used_words:
                    continue
                overlap = len(group_commits & word_commits[other_word])
                if overlap >= 0.3 * min(len(group_commits), len(word_commits[other_word])):
                    group_words.append(other_word)
                    group_commits |= word_commits[other_word]
                    used_words.add(other_word)

            groups.append({
                'words': group_words,
                'commit_count': len(group_commits)
            })

        groups.sort(key=lambda g: -g['commit_count'])
        top_groups = groups[:max_themes]

        themes = {}
        for group in top_groups:
            name = group['words'][0]
            themes[name] = {
                'keywords': group['words'][:8],
                'description': f"Changes related to {', '.join(group['words'][:3])}"
            }

        self.log(f"Discovered {len(themes)} themes")
        return themes

    def discover_periods(self, min_periods: int = 3, max_periods: int = 7) -> Dict[str, Dict[str, Any]]:
        """Discover time periods by analyzing commit date distribution."""
        self.log("Analyzing commit dates for period boundaries...")

        dated_commits = [c for c in self.commits if c.get('date') is not None]
        if len(dated_commits) < 2:
            return {
                'all': {
                    'start': '2000-01-01',
                    'end': '2030-12-31',
                    'description': 'All project history'
                }
            }

        dated_commits.sort(key=lambda c: c['date'])
        first_date = dated_commits[0]['date']
        last_date = dated_commits[-1]['date']

        # Build monthly commit histogram
        monthly: Dict[str, int] = defaultdict(int)
        for commit in dated_commits:
            month_key = commit['date'].strftime('%Y-%m')
            monthly[month_key] += 1

        # Generate all months in range
        all_months = []
        current = first_date.replace(day=1)
        end_month = last_date.replace(day=1)
        while current <= end_month:
            key = current.strftime('%Y-%m')
            all_months.append((key, monthly.get(key, 0)))
            if current.month == 12:
                current = current.replace(year=current.year + 1, month=1)
            else:
                current = current.replace(month=current.month + 1)

        if len(all_months) < 2:
            return {
                'all': {
                    'start': first_date.strftime('%Y-%m-%d'),
                    'end': '2030-12-31',
                    'description': 'All project history'
                }
            }

        # Find breakpoints: gaps and rate changes
        breakpoints = []
        counts = [m[1] for m in all_months]

        # Detect gaps (consecutive months with zero commits)
        gap_start = None
        for i, (month, count) in enumerate(all_months):
            if count == 0:
                if gap_start is None:
                    gap_start = i
            else:
                if gap_start is not None:
                    gap_len = i - gap_start
                    if gap_len >= 3:
                        breakpoints.append((i, gap_len * 10))
                    gap_start = None

        # Detect rate changes using sliding window comparison
        window = max(3, len(all_months) // 20)
        for i in range(window, len(all_months) - window):
            before = sum(counts[i - window:i]) / window
            after = sum(counts[i:i + window]) / window
            if before > 0 and after > 0:
                ratio = max(after / before, before / after)
                if ratio >= 2.0:
                    breakpoints.append((i, ratio * 5))

        # Sort by score and select top breakpoints
        breakpoints.sort(key=lambda x: -x[1])

        # Deduplicate nearby breakpoints (within 6 months)
        selected = []
        for bp_idx, bp_score in breakpoints:
            if not any(abs(bp_idx - s) < 6 for s in selected):
                selected.append(bp_idx)
            if len(selected) >= max_periods - 1:
                break

        # If we don't have enough breakpoints, add evenly spaced ones
        while len(selected) < min_periods - 1:
            segment_len = len(all_months) // (len(selected) + 2)
            for i in range(1, len(selected) + 2):
                candidate = i * segment_len
                if candidate < len(all_months) and not any(abs(candidate - s) < 6 for s in selected):
                    selected.append(candidate)
                    break
            else:
                break

        selected.sort()

        # Build periods from breakpoints
        periods = {}
        boundaries = [0] + selected + [len(all_months)]

        for i in range(len(boundaries) - 1):
            start_idx = boundaries[i]
            end_idx = boundaries[i + 1] - 1
            if end_idx < start_idx:
                end_idx = start_idx

            start_month = all_months[start_idx][0]
            end_month_key = all_months[min(end_idx, len(all_months) - 1)][0]

            start_date = f"{start_month}-01"
            # End date: last day of end month
            end_year, end_mon = end_month_key.split('-')
            if int(end_mon) == 12:
                end_date = f"{end_year}-12-31"
            else:
                next_month = datetime(int(end_year), int(end_mon) + 1, 1, tzinfo=timezone.utc)
                last_day = next_month - timedelta(days=1)
                end_date = last_day.strftime('%Y-%m-%d')

            commit_count = sum(
                all_months[j][1] for j in range(start_idx, min(end_idx + 1, len(all_months)))
            )

            name = f"period-{i + 1}"
            periods[name] = {
                'start': start_date,
                'end': end_date,
                'description': f"{commit_count} commits from {start_date} to {end_date}"
            }

        # Extend final period to future
        if periods:
            last_name = list(periods.keys())[-1]
            periods[last_name]['end'] = '2030-12-31'

        self.log(f"Discovered {len(periods)} periods")
        return periods

    def discover_importance_keywords(
        self,
        themes: Dict[str, Dict[str, Any]],
        max_keywords: int = 12
    ) -> Dict[str, List[str]]:
        """Discover importance keywords from themes and PR/MR data."""
        self.log("Discovering importance keywords...")

        # Collect top keywords from themes (most project-specific)
        arch_keywords = []
        for theme_data in themes.values():
            arch_keywords.extend(theme_data['keywords'][:2])

        # Add generic architectural terms that are always relevant
        generic_arch = ['architecture', 'redesign', 'rewrite', 'migration', 'breaking']
        for term in generic_arch:
            if term not in arch_keywords:
                arch_keywords.append(term)

        arch_keywords = arch_keywords[:max_keywords]

        # Title keywords from PR/MR titles of significant items
        title_keywords = []
        all_items = list(self.pr_data.values()) + list(self.mr_data.values())
        significant_items = [
            item for item in all_items
            if len(item.get('body', '')) > 1000 or item.get('body', '').count('###') >= 3
        ]

        if significant_items:
            title_word_freq: Dict[str, int] = defaultdict(int)
            for item in significant_items:
                tokens = self._tokenize(item.get('title', ''))
                for token in tokens:
                    title_word_freq[token] += 1

            ranked = sorted(title_word_freq.items(), key=lambda x: -x[1])
            title_keywords = [w for w, _ in ranked[:max_keywords]]

        # Fall back to generic + theme-derived if no PR/MR data
        if not title_keywords:
            title_keywords = ['breaking', 'migration', 'redesign', 'rewrite', 'rfc']
            for kw in arch_keywords[:5]:
                if kw not in title_keywords:
                    title_keywords.append(kw)
            title_keywords = title_keywords[:max_keywords]

        return {
            'architectural_keywords': arch_keywords,
            'title_keywords': title_keywords
        }


class HistoryGenerator:
    """Main history generation coordinator."""

    DEFAULT_PERIODS = {
        'period-1': {'start': '2000-01-01', 'end': '2005-12-31', 'description': 'Period 1'},
        'period-2': {'start': '2006-01-01', 'end': '2010-12-31', 'description': 'Period 2'},
        'period-3': {'start': '2011-01-01', 'end': '2015-12-31', 'description': 'Period 3'},
        'period-4': {'start': '2016-01-01', 'end': '2020-12-31', 'description': 'Period 4'},
        'period-5': {'start': '2021-01-01', 'end': '2030-12-31', 'description': 'Period 5'},
    }

    def __init__(self, repo_path: Path, history_path: Path, output_path: Path,
                 verbose: bool = False, resume: bool = True,
                 repo_configs: Optional[List[Dict[str, Any]]] = None,
                 themes: Optional[Dict[str, Dict[str, Any]]] = None,
                 periods: Optional[Dict[str, Dict[str, Any]]] = None,
                 architectural_keywords: Optional[List[str]] = None,
                 title_keywords: Optional[List[str]] = None):
        """
        Initialize the history generator.

        Args:
            repo_path: Path to git repository (single-repo mode)
            history_path: Path to history archive
            output_path: Output directory for generated files
            verbose: Enable verbose output
            resume: Resume from existing state
            repo_configs: For multi-repo mode, list of repo config dicts with
                          keys: name, local_path, platform. When set, repo_path
                          is ignored and commits are merged from all repos.
            themes: Optional dictionary of theme definitions for ThemeDetector
            periods: Optional dictionary of period definitions
            architectural_keywords: Optional list of architectural keywords for scoring
            title_keywords: Optional list of title keywords for PR scoring
        """
        self.history_path = history_path
        self.output_path = output_path
        self.verbose = verbose
        self.repo_configs = repo_configs
        self.periods = periods if periods is not None else self.DEFAULT_PERIODS

        self.state = StateManager(output_path / '.history-gen-state.json')
        self.theme_detector = ThemeDetector(themes=themes)
        self.scorer = ImportanceScorer(verbose, architectural_keywords=architectural_keywords, title_keywords=title_keywords)

        if repo_configs and len(repo_configs) > 1:
            self.repo_path = None
            self.git_analyzers = {
                rc['name']: GitAnalyzer(Path(rc['local_path']), verbose, repo_name=rc['name'])
                for rc in repo_configs
            }
            repo_data_paths = {
                rc['name']: history_path / "repos" / rc['name']
                for rc in repo_configs
            }
            self.correlator = IssueCorrelator(
                history_path, verbose, repo_data_paths=repo_data_paths
            )
        else:
            self.repo_path = repo_path
            self.git_analyzers = None
            self.correlator = IssueCorrelator(history_path, verbose)

        self.git = GitAnalyzer(repo_path, verbose) if not self.git_analyzers else None

        self.commits = []
        self.correlation = {}
        self.importance_scores = {}

        if not resume:
            self.state.state = StateManager(output_path / '.history-gen-state.json').state

    def log(self, message: str, force: bool = False):
        """Log message."""
        if self.verbose or force:
            print(message)

    def _get_all_commits(self) -> List[Dict[str, Any]]:
        """Get all commits, merging from multiple repos if configured."""
        if self.git_analyzers:
            all_commits = []
            for name, analyzer in self.git_analyzers.items():
                repo_commits = analyzer.get_all_commits()
                all_commits.extend(repo_commits)
            all_commits.sort(key=lambda c: c['date'])
            self.log(f"Merged {len(all_commits)} commits from {len(self.git_analyzers)} repositories", force=True)
            return all_commits
        else:
            return self.git.get_all_commits()

    def load_or_generate_correlation(self) -> Dict[str, Any]:
        """Load correlation data or generate it."""
        correlation_file = self.output_path / 'data' / 'correlation.json'

        if correlation_file.exists() and self.state.state.get('correlation_done'):
            self.log("Loading existing correlation data...")
            with open(correlation_file, 'r') as f:
                data = json.load(f)
                self.commits = data['commits']
                # Convert date strings back to datetime
                for commit in self.commits:
                    commit['date'] = datetime.fromisoformat(commit['date'])
                self.correlation = data['correlation']
                return data

        self.log("Generating correlation data...", force=True)

        # Get all commits (from single or multiple repos)
        self.commits = self._get_all_commits()

        # Correlate to PRs/MRs/Jira
        self.correlation = self.correlator.correlate_commits(self.commits)

        # Save correlation data
        correlation_file.parent.mkdir(parents=True, exist_ok=True)
        with open(correlation_file, 'w') as f:
            json.dump({
                'commits': [{
                    **c,
                    'date': c['date'].isoformat()
                } for c in self.commits],
                'correlation': self.correlation
            }, f, indent=2)

        self.state.state['correlation_done'] = True
        self.state.save()

        return {'commits': self.commits, 'correlation': self.correlation}

    def group_commits_by_period(self) -> Dict[str, List[Dict[str, Any]]]:
        """Group commits into time periods."""
        grouped = defaultdict(list)

        for commit in self.commits:
            commit_date = commit['date']

            for period_name, period_config in self.periods.items():
                start = datetime.fromisoformat(period_config['start']).replace(tzinfo=timezone.utc)
                end = datetime.fromisoformat(period_config['end']).replace(tzinfo=timezone.utc)

                if start <= commit_date <= end:
                    grouped[period_name].append(commit)
                    break

        return dict(grouped)

    def generate_timeline(self, period_name: str, commits: List[Dict[str, Any]]):
        """Generate timeline markdown for a period."""
        self.log(f"Generating timeline for {period_name}...")

        period_config = self.periods[period_name]

        output = [f"# {period_name.replace('-', ' ').title()} Timeline"]
        output.append(f"\n**Period**: {period_config['start']} to {period_config['end']}")
        output.append(f"\n**Description**: {period_config['description']}\n")
        output.append(f"\n**Total Commits**: {len(commits)}\n")

        # Group by month
        by_month = defaultdict(list)
        for commit in sorted(commits, key=lambda c: c['date']):
            month_key = commit['date'].strftime('%Y-%m')
            by_month[month_key].append(commit)

        # Generate monthly sections
        for month in sorted(by_month.keys()):
            month_commits = by_month[month]
            output.append(f"\n## {month} ({len(month_commits)} commits)\n")

            for commit in month_commits:
                refs = self.correlation.get(commit['sha'], {})
                ref_strs = []

                # Add GitHub PR reference
                if refs.get('github_pr'):
                    ref_strs.append(f"#{refs['github_pr']}")

                # Add GitLab MR reference
                if refs.get('gitlab_mr'):
                    ref_strs.append(f"!{refs['gitlab_mr']}")

                # Add Jira issue references
                for jira_key in refs.get('jira_issues', []):
                    ref_strs.append(jira_key)

                ref_text = f" [{', '.join(ref_strs)}]" if ref_strs else ""

                # Score and mark important commits
                # Try to get data from GitHub PR, GitLab MR, or first Jira issue
                issue_data = None
                ref_repo = refs.get('repo')
                if refs.get('github_pr'):
                    issue_data = self.correlator.get_github_prs(ref_repo).get(refs['github_pr'])
                elif refs.get('gitlab_mr'):
                    issue_data = self.correlator.get_gitlab_mrs(ref_repo).get(refs['gitlab_mr'])
                elif refs.get('jira_issues'):
                    issue_data = self.correlator.jira_issues.get(refs['jira_issues'][0])

                score = self.scorer.score_commit(commit, issue_data)
                importance_marker = " ⭐" if score >= 20 else ""

                date_str = commit['date'].strftime('%Y-%m-%d')
                repo_tag = f" `[{commit['repo']}]`" if commit.get('repo') else ""
                output.append(
                    f"- **{date_str}**: {commit['subject']}{ref_text}{importance_marker} "
                    f"_by @{commit['author']}_{repo_tag}\n"
                )

        # Write timeline file
        timeline_file = self.output_path / 'timeline' / f'{period_name}.md'
        timeline_file.parent.mkdir(parents=True, exist_ok=True)

        with open(timeline_file, 'w') as f:
            f.write('\n'.join(output))

        self.log(f"Timeline saved to {timeline_file}")

        # Update state
        if period_name not in self.state.state['timelines_generated']:
            self.state.state['timelines_generated'].append(period_name)
            self.state.save()

    def analyze_period_themes(self, commits: List[Dict[str, Any]]) -> Dict[str, List[Dict[str, Any]]]:
        """Analyze themes in a period."""
        themed = defaultdict(list)

        for commit in commits:
            themes = self.theme_detector.detect_themes(commit['message'])
            for theme in themes:
                themed[theme].append(commit)

        return dict(themed)

    def generate_all_timelines(self):
        """Generate timelines for all periods."""
        self.log("Generating timelines for all periods...", force=True)

        grouped = self.group_commits_by_period()

        for period_name in self.periods.keys():
            if period_name in self.state.state['timelines_generated']:
                self.log(f"Skipping {period_name} (already generated)")
                continue

            period_commits = grouped.get(period_name, [])
            if period_commits:
                self.generate_timeline(period_name, period_commits)

    def save_analysis_data(self):
        """Save analysis data for later use."""
        data_dir = self.output_path / 'data'
        data_dir.mkdir(parents=True, exist_ok=True)

        # Save importance scores for top GitHub PRs (across all repos)
        pr_scores = {}
        for repo_name, prs in self.correlator.all_github_prs().items():
            for pr_num, pr_data in prs.items():
                score = self.scorer.score_pr(pr_data)
                if score >= 15:
                    key = f"{repo_name}:{pr_num}" if repo_name else str(pr_num)
                    pr_scores[key] = {
                        'score': score,
                        'title': pr_data.get('title'),
                        'author': pr_data.get('author'),
                        'merged': pr_data.get('merged'),
                        'created': pr_data.get('created'),
                        'repo': repo_name
                    }

        if pr_scores:
            with open(data_dir / 'important_prs.json', 'w') as f:
                json.dump(pr_scores, f, indent=2)
            self.log(f"Saved {len(pr_scores)} important GitHub PRs to data/important_prs.json")

        # Save importance scores for top GitLab MRs (across all repos)
        mr_scores = {}
        for repo_name, mrs in self.correlator.all_gitlab_mrs().items():
            for mr_num, mr_data in mrs.items():
                score = self.scorer.score_pr(mr_data)
                if score >= 15:
                    key = f"{repo_name}:{mr_num}" if repo_name else str(mr_num)
                    mr_scores[key] = {
                        'score': score,
                        'title': mr_data.get('title'),
                        'author': mr_data.get('author'),
                        'merged': mr_data.get('merged_at') is not None,
                        'created': mr_data.get('created'),
                        'repo': repo_name
                    }

        if mr_scores:
            with open(data_dir / 'important_mrs.json', 'w') as f:
                json.dump(mr_scores, f, indent=2)
            self.log(f"Saved {len(mr_scores)} important GitLab MRs to data/important_mrs.json")

        # Save Jira issues referenced in commits
        jira_refs = {}
        for sha, refs in self.correlation.items():
            for jira_key in refs.get('jira_issues', []):
                if jira_key not in jira_refs:
                    jira_data = self.correlator.jira_issues.get(jira_key)
                    if jira_data:
                        jira_refs[jira_key] = {
                            'key': jira_key,
                            'summary': jira_data.get('summary'),
                            'status': jira_data.get('status'),
                            'issue_type': jira_data.get('issue_type'),
                            'created': jira_data.get('created')
                        }

        if jira_refs:
            with open(data_dir / 'jira_references.json', 'w') as f:
                json.dump(jira_refs, f, indent=2)
            self.log(f"Saved {len(jira_refs)} Jira references to data/jira_references.json")

        # Save theme analysis
        grouped = self.group_commits_by_period()
        theme_analysis = {}

        for period_name, period_commits in grouped.items():
            themes = self.analyze_period_themes(period_commits)
            theme_analysis[period_name] = {
                theme: len(commits) for theme, commits in themes.items()
            }

        with open(data_dir / 'theme_analysis.json', 'w') as f:
            json.dump(theme_analysis, f, indent=2)

        self.log("Saved theme analysis to data/theme_analysis.json")

    def run(self, phase: Optional[str] = None):
        """Run history generation."""
        self.log("=== Project History Generator ===", force=True)
        if self.git_analyzers:
            self.log(f"Repositories: {', '.join(self.git_analyzers.keys())}", force=True)
        else:
            self.log(f"Repository: {self.repo_path}", force=True)
        self.log(f"Output: {self.output_path}", force=True)
        self.log("", force=True)

        # Phase 1: Correlation
        if phase in [None, 'correlation']:
            self.load_or_generate_correlation()
            self.log("", force=True)

        # Phase 2: Timelines
        if phase in [None, 'timelines']:
            self.generate_all_timelines()
            self.log("", force=True)

        # Phase 3: Analysis data
        if phase in [None, 'analysis']:
            self.save_analysis_data()
            self.log("", force=True)

        self.log("=== Generation complete ===", force=True)
        self.log(f"State saved to {self.state.state_file}", force=True)


ANALYSIS_CONFIG_FILENAME = '.history-analysis-config.json'


def load_analysis_config(search_dir: Path) -> Optional[Dict[str, Any]]:
    """Load analysis config from .history-analysis-config.json."""
    config_path = search_dir / ANALYSIS_CONFIG_FILENAME
    if not config_path.exists():
        return None

    with open(config_path, 'r') as f:
        raw = json.load(f)

    result = {}
    if 'themes' in raw:
        result['themes'] = raw['themes']
    if 'periods' in raw:
        result['periods'] = raw['periods']
    if 'importance' in raw:
        result['importance'] = raw['importance']

    return result if result else None


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Generate project history from git commits and issues/PRs/MRs/tickets",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
For multi-repository projects, use --config to read repository paths from
the project configuration file (.project-history-config.json).

Single-repo mode (default):
  %(prog)s --repo . --history ./history

Multi-repo mode (via config):
  %(prog)s --config .project-history-config.json
        """
    )

    parser.add_argument(
        '--config',
        help='Configuration file for multi-repo support (reads repo paths from config)'
    )
    parser.add_argument(
        '--repo',
        default='.',
        help='Path to git repository (default: current directory, ignored with --config)'
    )
    parser.add_argument(
        '--history',
        default='./history',
        help='Path to history archive (default: ./history)'
    )
    parser.add_argument(
        '--output',
        default='./history/draft',
        help='Output directory (default: ./history/draft)'
    )
    parser.add_argument(
        '--phase',
        choices=['correlation', 'timelines', 'analysis'],
        help='Run only specific phase'
    )
    parser.add_argument(
        '--no-resume',
        action='store_true',
        help='Start fresh (ignore existing state)'
    )
    parser.add_argument(
        '--verbose',
        action='store_true',
        help='Verbose output'
    )
    parser.add_argument(
        '--discover',
        action='store_true',
        help='Analyze git history to auto-generate .history-analysis-config.json and exit'
    )

    args = parser.parse_args()

    repo_configs = None
    history_path = Path(args.history)
    output_path = Path(args.output)
    repo_path = Path(args.repo)

    # Auto-discover config file if not explicitly provided
    if not args.config:
        script_dir = Path(__file__).parent.resolve()
        candidates = [
            Path('.project-history-config.json'),
            script_dir / '.project-history-config.json',
        ]
        if script_dir.name == 'tools':
            candidates.append(script_dir.parent / '.project-history-config.json')
        for candidate in candidates:
            if candidate.exists():
                args.config = str(candidate)
                break

    if args.config:
        config_file = Path(args.config)
        if not config_file.exists():
            script_dir = Path(__file__).parent.resolve()
            alt = script_dir / config_file.name
            if alt.exists():
                config_file = alt
            elif script_dir.name == 'tools':
                alt2 = script_dir.parent / config_file.name
                if alt2.exists():
                    config_file = alt2
            if not config_file.exists():
                print(f"Error: Configuration file not found: {config_file}", file=sys.stderr)
                sys.exit(1)

        with open(config_file, 'r') as f:
            raw_config = json.load(f)

        config = normalize_config(raw_config)
        repo_configs = config.get('repos', [])

        # Resolve relative paths against config file location, not CWD
        config_dir = config_file.parent.resolve()
        for rc in repo_configs:
            rc['local_path'] = str((config_dir / rc['local_path']).resolve())
        history_path = (config_dir / config.get('output_dir', './history')).resolve()
        output_path = history_path / 'draft'

        if not repo_configs:
            print("Error: No repositories found in config", file=sys.stderr)
            sys.exit(1)

        if len(repo_configs) == 1:
            repo_path = Path(repo_configs[0]['local_path'])
            repo_configs = None

    # Determine where to look for analysis config
    if args.config:
        analysis_config_dir = config_file.parent.resolve()
    else:
        script_dir = Path(__file__).parent.resolve()
        analysis_config_dir = None
        for candidate_dir in [Path('.').resolve(), script_dir]:
            if (candidate_dir / ANALYSIS_CONFIG_FILENAME).exists():
                analysis_config_dir = candidate_dir
                break
        if analysis_config_dir is None and script_dir.name == 'tools':
            parent = script_dir.parent
            if (parent / ANALYSIS_CONFIG_FILENAME).exists():
                analysis_config_dir = parent
        if analysis_config_dir is None:
            analysis_config_dir = Path('.').resolve()

    # Load analysis config if it exists
    analysis_config = load_analysis_config(analysis_config_dir)
    themes = None
    periods = None
    architectural_keywords = None
    title_keywords = None

    if analysis_config:
        themes = analysis_config.get('themes')
        periods = analysis_config.get('periods')
        importance = analysis_config.get('importance', {})
        architectural_keywords = importance.get('architectural_keywords')
        title_keywords = importance.get('title_keywords')

    if args.discover:
        try:
            # Collect commits from all configured repos
            if repo_configs:
                commits = []
                for rc in repo_configs:
                    git = GitAnalyzer(Path(rc['local_path']), args.verbose, repo_name=rc['name'])
                    commits.extend(git.get_all_commits())
                commits.sort(key=lambda c: c['date'])
            else:
                git = GitAnalyzer(repo_path, args.verbose)
                commits = git.get_all_commits()

            # Load PR/MR data for importance keyword discovery
            pr_data = {}
            mr_data = {}
            if repo_configs:
                repo_data_paths = {
                    rc['name']: history_path / "repos" / rc['name']
                    for rc in repo_configs
                }
                correlator = IssueCorrelator(history_path, args.verbose, repo_data_paths=repo_data_paths)
                for prs in correlator.all_github_prs().values():
                    pr_data.update(prs)
                for mrs in correlator.all_gitlab_mrs().values():
                    mr_data.update(mrs)
            else:
                correlator = IssueCorrelator(history_path, args.verbose)
                pr_data = correlator.github_prs
                mr_data = correlator.gitlab_mrs

            analyzer = DiscoveryAnalyzer(
                commits, pr_data=pr_data, mr_data=mr_data, verbose=args.verbose
            )

            themes = analyzer.discover_themes()
            periods = analyzer.discover_periods()
            importance = analyzer.discover_importance_keywords(themes)

            config_out = {
                'themes': themes,
                'periods': periods,
                'importance': importance
            }

            config_path = analysis_config_dir / ANALYSIS_CONFIG_FILENAME
            if config_path.exists():
                print(f"Warning: Overwriting existing {config_path}", file=sys.stderr)

            with open(config_path, 'w') as f:
                json.dump(config_out, f, indent=2)

            # Print summary
            print(f"\n=== Discovery Complete ===")
            print(f"Analyzed {len(commits)} commits\n")

            print(f"Themes ({len(themes)}):")
            for name, data in themes.items():
                kw_list = ', '.join(data['keywords'][:5])
                print(f"  {name}: {data['description']} [{kw_list}]")

            print(f"\nPeriods ({len(periods)}):")
            for name, data in periods.items():
                print(f"  {name}: {data['start']} to {data['end']} — {data['description']}")

            print(f"\nImportance keywords:")
            print(f"  Architectural: {', '.join(importance['architectural_keywords'])}")
            print(f"  Title: {', '.join(importance['title_keywords'])}")

            print(f"\nConfig written to: {config_path}")
            print(f"Review and customize before running: generate-history-draft --verbose")

        except Exception as e:
            print(f"Error during discovery: {e}", file=sys.stderr)
            if args.verbose:
                import traceback
                traceback.print_exc()
            sys.exit(1)
        sys.exit(0)

    try:
        generator = HistoryGenerator(
            repo_path=repo_path,
            history_path=history_path,
            output_path=output_path,
            verbose=args.verbose,
            resume=not args.no_resume,
            repo_configs=repo_configs,
            themes=themes,
            periods=periods,
            architectural_keywords=architectural_keywords,
            title_keywords=title_keywords
        )
        generator.run(phase=args.phase)
    except KeyboardInterrupt:
        print("\nInterrupted by user", file=sys.stderr)
        sys.exit(130)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        if args.verbose:
            import traceback
            traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    main()
