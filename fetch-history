#!/usr/bin/env python3
"""
Unified history fetcher for multi-platform projects.

This script reads .project-history-config.json and fetches data from
all configured platforms (GitHub, GitLab, Jira).
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Dict, List

SCRIPT_DIR = Path(__file__).parent.resolve()


class Color:
    """ANSI color codes."""
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    END = '\033[0m'
    BOLD = '\033[1m'


def print_header(text: str):
    """Print a formatted header."""
    print(f"\n{Color.BOLD}{Color.HEADER}{'=' * 70}")
    print(f"  {text}")
    print(f"{'=' * 70}{Color.END}\n")


def print_info(text: str):
    """Print an info message."""
    print(f"{Color.CYAN}ℹ️  {text}{Color.END}")


def print_success(text: str):
    """Print a success message."""
    print(f"{Color.GREEN}✓ {text}{Color.END}")


def print_warning(text: str):
    """Print a warning message."""
    print(f"{Color.YELLOW}⚠️  {text}{Color.END}")


def print_error(text: str):
    """Print an error message."""
    print(f"{Color.RED}✗ {text}{Color.END}", file=sys.stderr)


def load_config(config_file: Path) -> Dict:
    """Load project configuration."""
    if not config_file.exists():
        print_error(f"Configuration file not found: {config_file}")
        print_info("Run './setup-project' to create configuration")
        sys.exit(1)

    with open(config_file, 'r') as f:
        return json.load(f)


def _normalize_jira_config(jira_config: Dict) -> Dict:
    """
    Normalize Jira config to the multi-project format.

    Accepts both old format (single project_key string) and new format
    (projects array). Returns config with a 'projects' array.
    """
    if not jira_config.get('enabled', False):
        return jira_config

    if 'projects' in jira_config:
        return jira_config

    if 'project_key' in jira_config:
        project_key = jira_config['project_key']
        return {
            'enabled': True,
            'url': jira_config.get('url', ''),
            'projects': [{'project_key': project_key}],
        }

    return jira_config


def normalize_config(config: Dict) -> Dict:
    """
    Normalize configuration to a uniform multi-repo format.

    Converts single-repo configs (platforms.github/gitlab as objects) to the
    multi-repo format (repos array) for uniform processing.

    Returns:
        Dict with 'repos' list, 'platforms' (jira only), and 'output_dir'
    """
    if 'repos' in config:
        config = dict(config)
        jira = config.get('platforms', {}).get('jira', {'enabled': False})
        config['platforms'] = dict(config.get('platforms', {}))
        config['platforms']['jira'] = _normalize_jira_config(jira)
        return config

    repos = []
    platforms = config.get('platforms', {})

    github = platforms.get('github', {})
    if github.get('enabled'):
        repos.append({
            'name': github['repo'],
            'local_path': '.',
            'platform': 'github',
            'owner': github['owner'],
            'repo': github['repo'],
        })

    gitlab = platforms.get('gitlab', {})
    if gitlab.get('enabled'):
        project_id = gitlab['project_id']
        repos.append({
            'name': project_id.split('/')[-1],
            'local_path': '.',
            'platform': 'gitlab',
            'project_id': project_id,
            'url': gitlab['url'],
        })

    return {
        'repos': repos,
        'platforms': {'jira': _normalize_jira_config(platforms.get('jira', {'enabled': False}))},
        'output_dir': config.get('output_dir', './history'),
    }


def is_multi_repo(config: Dict) -> bool:
    """Check if config describes multiple repositories."""
    normalized = normalize_config(config)
    return len(normalized['repos']) > 1


def check_environment_variable(var_name: str) -> bool:
    """Check if an environment variable is set."""
    value = os.getenv(var_name)
    if value:
        print_success(f"{var_name} is set")
        return True
    else:
        print_error(f"{var_name} is not set")
        return False


def run_command(cmd: List[str], description: str, verbose: bool = False) -> bool:
    """
    Run a command and return success status.

    Args:
        cmd: Command to run
        description: Description for logging
        verbose: Pass verbose flag to subprocess

    Returns:
        True if successful, False otherwise
    """
    print_info(f"Running: {description}")

    # Add verbose flag if requested
    if verbose and '--verbose' not in cmd:
        cmd.append('--verbose')

    env = os.environ.copy()
    env['PYTHONUNBUFFERED'] = '1'

    try:
        result = subprocess.run(cmd, check=True, env=env)
        print_success(f"Completed: {description}")
        return True
    except subprocess.CalledProcessError as e:
        print_error(f"Failed: {description} (exit code {e.returncode})")
        return False
    except FileNotFoundError:
        print_error(f"Command not found: {cmd[0]}")
        print_info(f"Make sure the script exists and is executable: chmod +x {cmd[0]}")
        return False


def fetch_github_repo(repo_config: Dict, output_dir: str, verbose: bool, state_filter: str) -> bool:
    """Fetch GitHub data for a single repository."""
    repo = f"{repo_config['owner']}/{repo_config['repo']}"
    print_header(f"Fetching GitHub Data: {repo}")

    if not check_environment_variable('GITHUB_TOKEN'):
        return False

    cmd = [
        str(SCRIPT_DIR / 'fetch-github-history'),
        '--repo', repo,
        '--output', output_dir,
        '--state', state_filter
    ]

    return run_command(cmd, f"GitHub: {repo}", verbose)


def fetch_gitlab_repo(repo_config: Dict, output_dir: str, verbose: bool, state_filter: str) -> bool:
    """Fetch GitLab data for a single repository."""
    project_id = repo_config['project_id']
    gitlab_url = repo_config['url']
    print_header(f"Fetching GitLab Data: {project_id}")

    if not check_environment_variable('GITLAB_TOKEN'):
        return False

    cmd = [
        str(SCRIPT_DIR / 'fetch-gitlab-history'),
        '--project', project_id,
        '--gitlab-url', gitlab_url,
        '--output', output_dir,
        '--state', state_filter
    ]

    return run_command(cmd, f"GitLab: {project_id}", verbose)


def fetch_repo(repo_config: Dict, output_dir: str, verbose: bool, state_filter: str) -> bool:
    """Fetch data for a single repository based on its platform."""
    platform = repo_config['platform']
    if platform == 'github':
        return fetch_github_repo(repo_config, output_dir, verbose, state_filter)
    elif platform == 'gitlab':
        return fetch_gitlab_repo(repo_config, output_dir, verbose, state_filter)
    else:
        print_error(f"Unknown platform: {platform}")
        return False


def fetch_jira(jira_config: Dict, output_dir: str, verbose: bool, status_filter: str = None) -> bool:
    """Fetch Jira data for all configured projects."""
    print_header("Fetching Jira Data")

    jira_url = jira_config['url']
    projects = jira_config.get('projects', [])

    if not check_environment_variable('JIRA_TOKEN'):
        return False

    all_success = True
    for project in projects:
        project_key = project['project_key']
        jql_filter = project.get('jql_filter')

        label = project_key
        if jql_filter:
            label += f" (filter: {jql_filter})"
        print_info(f"Fetching Jira project: {label}")

        env = os.environ.copy()
        env['PYTHONUNBUFFERED'] = '1'
        env['JIRA_URL'] = jira_url
        env['JIRA_PROJECT'] = project_key

        cmd = [
            str(SCRIPT_DIR / 'fetch-jira-history'),
            '--project', project_key,
            '--jira-url', jira_url,
            '--output', output_dir,
        ]

        if status_filter:
            cmd.extend(['--status', status_filter])
        if jql_filter:
            cmd.extend(['--jql', jql_filter])
        if verbose:
            cmd.append('--verbose')

        try:
            result = subprocess.run(cmd, check=True, env=env)
            print_success(f"Completed: Jira: {project_key}")
        except subprocess.CalledProcessError as e:
            print_error(f"Failed: Jira: {project_key} (exit code {e.returncode})")
            all_success = False
        except FileNotFoundError:
            print_error(f"Command not found: {cmd[0]}")
            all_success = False

    return all_success


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Fetch history from all configured platforms",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
This script reads .project-history-config.json and fetches data from
all enabled platforms (GitHub, GitLab, Jira).

Supports both single-repo and multi-repo configurations.
For multi-repo projects, data is stored under history/repos/<name>/.

Before running, ensure environment variables are set:
  GITHUB_TOKEN - for GitHub (if enabled)
  GITLAB_TOKEN - for GitLab (if enabled)
  JIRA_TOKEN   - for Jira (if enabled)

Run './setup-project' if configuration doesn't exist.
        """
    )

    parser.add_argument(
        '--config',
        default='.project-history-config.json',
        help='Configuration file (default: .project-history-config.json)'
    )
    parser.add_argument(
        '--only-github',
        action='store_true',
        help='Fetch only from GitHub repositories'
    )
    parser.add_argument(
        '--only-gitlab',
        action='store_true',
        help='Fetch only from GitLab repositories'
    )
    parser.add_argument(
        '--only-jira',
        action='store_true',
        help='Fetch only from Jira'
    )
    parser.add_argument(
        '--only-repo',
        help='Fetch only from a specific repo by name (multi-repo configs)'
    )
    parser.add_argument(
        '--state',
        choices=['all', 'open', 'closed', 'merged'],
        default='all',
        help='Filter by state for GitHub/GitLab (default: all)'
    )
    parser.add_argument(
        '--jira-status',
        help='Filter Jira issues by status (e.g., "Done", "In Progress")'
    )
    parser.add_argument(
        '--verbose',
        action='store_true',
        help='Enable verbose output'
    )

    args = parser.parse_args()

    # Load configuration: check CWD, then script's directory, then project root
    config_file = Path(args.config)
    if not config_file.exists():
        script_dir = Path(__file__).parent.resolve()
        alt = script_dir / config_file.name
        if alt.exists():
            config_file = alt
        elif script_dir.name == 'tools':
            alt2 = script_dir.parent / config_file.name
            if alt2.exists():
                config_file = alt2
    raw_config = load_config(config_file)
    config = normalize_config(raw_config)

    # Resolve relative paths against config file location, not CWD
    config_dir = config_file.parent.resolve()
    output_dir = str((config_dir / config.get('output_dir', './history')).resolve())
    repos = config.get('repos', [])
    jira_config = config.get('platforms', {}).get('jira', {'enabled': False})
    multi = len(repos) > 1

    # Filter repos by platform or name
    if args.only_github:
        repos = [r for r in repos if r['platform'] == 'github']
    elif args.only_gitlab:
        repos = [r for r in repos if r['platform'] == 'gitlab']
    elif args.only_jira:
        repos = []

    if args.only_repo:
        repos = [r for r in repos if r['name'] == args.only_repo]
        if not repos:
            print_error(f"No repository named '{args.only_repo}' found in config")
            sys.exit(1)

    fetch_jira_data = jira_config.get('enabled', False) and not args.only_github and not args.only_gitlab and not args.only_repo

    if args.only_jira:
        fetch_jira_data = jira_config.get('enabled', False)

    # Print summary
    print_header("Project History Fetcher")
    print_info(f"Configuration: {config_file}")
    print_info(f"Output directory: {output_dir}")
    if multi:
        print_info("Mode: multi-repository")
    print()

    if repos:
        print("Repositories:")
        for repo in repos:
            project_desc = repo.get('project_id') or f"{repo.get('owner')}/{repo.get('repo')}"
            print(f"  • {repo['name']} ({repo['platform'].title()}: {project_desc})")
    if fetch_jira_data:
        for proj in jira_config.get('projects', []):
            label = proj['project_key']
            if proj.get('jql_filter'):
                label += f" (filter: {proj['jql_filter']})"
            print(f"  • Jira: {label}")

    if not repos and not fetch_jira_data:
        print_warning("No platforms to fetch from. Run './setup-project' to configure.")
        sys.exit(0)

    # Track results
    results = {}

    # Fetch from each repository
    for repo in repos:
        if multi:
            repo_output_dir = str(Path(output_dir) / "repos" / repo['name'])
        else:
            repo_output_dir = output_dir

        result_key = f"{repo['platform']}:{repo['name']}" if multi else repo['platform']
        results[result_key] = fetch_repo(repo, repo_output_dir, args.verbose, args.state)

    # Fetch Jira (shared, always at top-level output_dir)
    if fetch_jira_data:
        results['jira'] = fetch_jira(jira_config, output_dir, args.verbose, args.jira_status)

    # Print summary
    print_header("Summary")

    success_count = sum(1 for success in results.values() if success)
    total_count = len(results)

    for source, success in results.items():
        status = "✓ Success" if success else "✗ Failed"
        color = Color.GREEN if success else Color.RED
        print(f"{color}{source}: {status}{Color.END}")

    print()
    if success_count == total_count:
        print_success(f"All {total_count} source(s) fetched successfully!")
        print()
        print_info("Next step: Run './generate-history-draft' to analyze the data")
    else:
        print_warning(f"{success_count}/{total_count} source(s) fetched successfully")
        print_info("Check error messages above and verify environment variables")
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\nInterrupted by user")
        sys.exit(130)
    except Exception as e:
        print_error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
