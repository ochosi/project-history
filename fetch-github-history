#!/usr/bin/env python3
"""
Fetch GitHub issues and pull requests for the repository and save as markdown files.

This tool fetches all issues and pull requests from the GitHub repository,
including their discussions, comments, and reviews, and saves them as
organized markdown files in the history/ directory.
"""

import argparse
import hashlib
import json
import os
import re
import sys
import time
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional, Any
from urllib.parse import urlparse

try:
    import requests
except ImportError:
    print("Error: 'requests' library is required. Install with: pip install requests", file=sys.stderr)
    sys.exit(1)


class GitHubHistoryFetcher:
    """Fetches and saves GitHub issues and pull requests as markdown files."""

    API_BASE = "https://api.github.com"
    GRAPHQL_ENDPOINT = "https://api.github.com/graphql"
    RATE_LIMIT_THRESHOLD = 100
    MAX_RETRIES = 3
    RETRY_DELAY = 5

    def __init__(self, owner: str, repo: str, token: str, output_dir: str, verbose: bool = False):
        """
        Initialize the fetcher.

        Args:
            owner: Repository owner (e.g., 'osbuild')
            repo: Repository name (e.g., 'osbuild')
            token: GitHub personal access token
            output_dir: Directory to save markdown files
            verbose: Enable verbose logging
        """
        self.owner = owner
        self.repo = repo
        self.token = token
        self.output_dir = Path(output_dir)
        self.verbose = verbose
        self.session = requests.Session()
        self.session.headers.update({
            "Authorization": f"token {token}",
            "Accept": "application/vnd.github.v3+json",
        })
        self.stats = {
            "issues_fetched": 0,
            "prs_fetched": 0,
            "api_calls": 0,
        }

    def log(self, message: str, force: bool = False):
        """Log a message if verbose mode is enabled."""
        if self.verbose or force:
            print(message)

    def check_rate_limit(self):
        """Check GitHub API rate limit and wait if necessary."""
        response = self.session.get(f"{self.API_BASE}/rate_limit")
        response.raise_for_status()
        data = response.json()

        remaining = data["resources"]["core"]["remaining"]
        reset_time = data["resources"]["core"]["reset"]

        self.log(f"Rate limit: {remaining} requests remaining")

        if remaining < self.RATE_LIMIT_THRESHOLD:
            wait_time = reset_time - time.time()
            if wait_time > 0:
                self.log(f"Rate limit low. Waiting {int(wait_time)} seconds...", force=True)
                time.sleep(wait_time + 1)

    def graphql_query(self, query: str, variables: Dict[str, Any]) -> Dict[str, Any]:
        """
        Execute a GraphQL query.

        Args:
            query: GraphQL query string
            variables: Query variables

        Returns:
            Query response data
        """
        self.stats["api_calls"] += 1

        for attempt in range(self.MAX_RETRIES):
            try:
                response = self.session.post(
                    self.GRAPHQL_ENDPOINT,
                    json={"query": query, "variables": variables},
                    headers={"Authorization": f"bearer {self.token}"}
                )
                response.raise_for_status()
                data = response.json()

                if "errors" in data:
                    raise Exception(f"GraphQL errors: {data['errors']}")

                return data["data"]

            except requests.exceptions.RequestException as e:
                if attempt < self.MAX_RETRIES - 1:
                    wait = self.RETRY_DELAY * (2 ** attempt)
                    self.log(f"Request failed: {e}. Retrying in {wait}s...", force=True)
                    time.sleep(wait)
                else:
                    raise

    def sanitize_filename(self, text: str, max_length: int = 50) -> str:
        """
        Sanitize text for use as a filename.

        Args:
            text: Text to sanitize
            max_length: Maximum length of filename

        Returns:
            Sanitized filename
        """
        # Remove or replace invalid characters
        text = re.sub(r'[<>:"/\\|?*]', '', text)
        text = re.sub(r'\s+', '-', text)
        text = text.strip('-').lower()

        # Truncate if too long
        if len(text) > max_length:
            text = text[:max_length].rstrip('-')

        return text or "untitled"

    def get_filename(self, number: int, title: str, existing_files: set) -> str:
        """
        Generate a unique filename for an issue or PR.

        Args:
            number: Issue/PR number
            title: Issue/PR title
            existing_files: Set of existing filenames to avoid conflicts

        Returns:
            Unique filename
        """
        sanitized_title = self.sanitize_filename(title)
        filename = f"{number:04d}-{sanitized_title}.md"

        # Handle conflicts by appending hash
        if filename in existing_files:
            hash_suffix = hashlib.md5(f"{number}{title}".encode()).hexdigest()[:8]
            filename = f"{number:04d}-{sanitized_title}-{hash_suffix}.md"

        existing_files.add(filename)
        return filename

    def format_date(self, date_str: Optional[str]) -> str:
        """Format ISO date string to human-readable format."""
        if not date_str:
            return "N/A"
        try:
            dt = datetime.fromisoformat(date_str.replace('Z', '+00:00'))
            return dt.strftime("%B %d, %Y at %I:%M %p UTC")
        except (ValueError, AttributeError):
            return date_str or "N/A"

    def generate_issue_markdown(self, issue: Dict[str, Any]) -> str:
        """
        Generate markdown content for an issue.

        Args:
            issue: Issue data from GitHub API

        Returns:
            Markdown content
        """
        author = issue.get("author", {})
        author_login = author.get("login", "[deleted]") if author else "[deleted]"

        labels = [label["name"] for label in issue.get("labels", {}).get("nodes", [])]
        labels_str = ", ".join(f"`{label}`" for label in labels) if labels else "None"

        url = f"https://github.com/{self.owner}/{self.repo}/issues/{issue['number']}"

        markdown = f"""---
type: issue
number: {issue['number']}
title: {json.dumps(issue['title'])}
state: {issue['state'].lower()}
author: {author_login}
created: {issue['createdAt']}
updated: {issue['updatedAt']}
"""

        if issue.get('closedAt'):
            markdown += f"closed: {issue['closedAt']}\n"

        markdown += f"""labels: {json.dumps(labels)}
url: {url}
---

# Issue #{issue['number']}: {issue['title']}

**Author**: @{author_login}
**Created**: {self.format_date(issue['createdAt'])}
**Status**: {issue['state'].title()}
**Labels**: {labels_str}

## Description

{issue.get('body', '') or '*No description provided*'}

"""

        # Add comments
        comments = issue.get("comments", {}).get("nodes", [])
        if comments:
            markdown += "---\n\n## Discussion\n\n"
            for comment in comments:
                comment_author = comment.get("author", {})
                comment_author_login = comment_author.get("login", "[deleted]") if comment_author else "[deleted]"
                markdown += f"### Comment by @{comment_author_login} on {self.format_date(comment['createdAt'])}\n\n"
                markdown += f"{comment.get('body', '')}\n\n"

        markdown += f"---\n\n*Archived from: {url}*\n"

        return markdown

    def generate_pr_markdown(self, pr: Dict[str, Any]) -> str:
        """
        Generate markdown content for a pull request.

        Args:
            pr: Pull request data from GitHub API

        Returns:
            Markdown content
        """
        author = pr.get("author", {})
        author_login = author.get("login", "[deleted]") if author else "[deleted]"

        labels = [label["name"] for label in pr.get("labels", {}).get("nodes", [])]
        labels_str = ", ".join(f"`{label}`" for label in labels) if labels else "None"

        state = "merged" if pr.get("merged") else pr["state"].lower()
        url = f"https://github.com/{self.owner}/{self.repo}/pull/{pr['number']}"

        markdown = f"""---
type: pull_request
number: {pr['number']}
title: {json.dumps(pr['title'])}
state: {state}
author: {author_login}
created: {pr['createdAt']}
updated: {pr['updatedAt']}
"""

        if pr.get('closedAt'):
            markdown += f"closed: {pr['closedAt']}\n"
        if pr.get('mergedAt'):
            markdown += f"merged: {pr['mergedAt']}\n"

        markdown += f"""base_branch: {pr.get('baseRefName', 'N/A')}
head_branch: {pr.get('headRefName', 'N/A')}
labels: {json.dumps(labels)}
url: {url}
---

# Pull Request #{pr['number']}: {pr['title']}

**Author**: @{author_login}
**Created**: {self.format_date(pr['createdAt'])}
**Status**: {state.title()}
**Labels**: {labels_str}
**Base**: `{pr.get('baseRefName', 'N/A')}` ← **Head**: `{pr.get('headRefName', 'N/A')}`

## Description

{pr.get('body', '') or '*No description provided*'}

"""

        # Add comments
        comments = pr.get("comments", {}).get("nodes", [])
        if comments:
            markdown += "---\n\n## Discussion\n\n"
            for comment in comments:
                comment_author = comment.get("author", {})
                comment_author_login = comment_author.get("login", "[deleted]") if comment_author else "[deleted]"
                markdown += f"### Comment by @{comment_author_login} on {self.format_date(comment['createdAt'])}\n\n"
                markdown += f"{comment.get('body', '')}\n\n"

        # Add reviews
        reviews = pr.get("reviews", {}).get("nodes", [])
        if reviews:
            markdown += "---\n\n## Reviews\n\n"
            for review in reviews:
                review_author = review.get("author", {})
                review_author_login = review_author.get("login", "[deleted]") if review_author else "[deleted]"
                review_state = review.get("state", "COMMENTED").replace("_", " ").title()
                markdown += f"### Review by @{review_author_login} - {review_state} on {self.format_date(review['createdAt'])}\n\n"
                if review.get('body'):
                    markdown += f"{review['body']}\n\n"

        markdown += f"---\n\n*Archived from: {url}*\n"

        return markdown

    def save_markdown(self, filepath: Path, content: str):
        """Save markdown content to file."""
        filepath.parent.mkdir(parents=True, exist_ok=True)
        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(content)

    def fetch_issues(self, state_filter: str = "all") -> List[Dict[str, Any]]:
        """
        Fetch all issues using GraphQL.

        Args:
            state_filter: Filter by state ('all', 'open', 'closed')

        Returns:
            List of issue data
        """
        query = """
        query($owner: String!, $repo: String!, $cursor: String, $states: [IssueState!]) {
          repository(owner: $owner, name: $repo) {
            issues(first: 100, after: $cursor, states: $states, orderBy: {field: CREATED_AT, direction: ASC}) {
              pageInfo {
                hasNextPage
                endCursor
              }
              nodes {
                number
                title
                state
                createdAt
                updatedAt
                closedAt
                author {
                  login
                }
                labels(first: 20) {
                  nodes {
                    name
                  }
                }
                body
                comments(first: 100) {
                  nodes {
                    author {
                      login
                    }
                    createdAt
                    body
                  }
                }
              }
            }
          }
        }
        """

        states = None
        if state_filter == "open":
            states = ["OPEN"]
        elif state_filter == "closed":
            states = ["CLOSED"]

        issues = []
        cursor = None
        has_next = True

        while has_next:
            self.check_rate_limit()

            variables = {
                "owner": self.owner,
                "repo": self.repo,
                "cursor": cursor,
                "states": states
            }

            self.log(f"Fetching issues page (cursor: {cursor})...")
            data = self.graphql_query(query, variables)

            page_issues = data["repository"]["issues"]["nodes"]
            issues.extend(page_issues)

            page_info = data["repository"]["issues"]["pageInfo"]
            has_next = page_info["hasNextPage"]
            cursor = page_info["endCursor"]

            self.log(f"Fetched {len(page_issues)} issues (total: {len(issues)})")

        return issues

    def fetch_pull_requests(self, state_filter: str = "all") -> List[Dict[str, Any]]:
        """
        Fetch all pull requests using GraphQL.

        Args:
            state_filter: Filter by state ('all', 'open', 'closed', 'merged')

        Returns:
            List of pull request data
        """
        query = """
        query($owner: String!, $repo: String!, $cursor: String, $states: [PullRequestState!]) {
          repository(owner: $owner, name: $repo) {
            pullRequests(first: 100, after: $cursor, states: $states, orderBy: {field: CREATED_AT, direction: ASC}) {
              pageInfo {
                hasNextPage
                endCursor
              }
              nodes {
                number
                title
                state
                createdAt
                updatedAt
                closedAt
                mergedAt
                merged
                author {
                  login
                }
                baseRefName
                headRefName
                labels(first: 20) {
                  nodes {
                    name
                  }
                }
                body
                comments(first: 100) {
                  nodes {
                    author {
                      login
                    }
                    createdAt
                    body
                  }
                }
                reviews(first: 100) {
                  nodes {
                    author {
                      login
                    }
                    state
                    createdAt
                    body
                  }
                }
              }
            }
          }
        }
        """

        states = None
        if state_filter == "open":
            states = ["OPEN"]
        elif state_filter == "closed":
            states = ["CLOSED", "MERGED"]

        prs = []
        cursor = None
        has_next = True

        while has_next:
            self.check_rate_limit()

            variables = {
                "owner": self.owner,
                "repo": self.repo,
                "cursor": cursor,
                "states": states
            }

            self.log(f"Fetching pull requests page (cursor: {cursor})...")
            data = self.graphql_query(query, variables)

            page_prs = data["repository"]["pullRequests"]["nodes"]
            prs.extend(page_prs)

            page_info = data["repository"]["pullRequests"]["pageInfo"]
            has_next = page_info["hasNextPage"]
            cursor = page_info["endCursor"]

            self.log(f"Fetched {len(page_prs)} PRs (total: {len(prs)})")

        # Filter merged PRs if requested
        if state_filter == "merged":
            prs = [pr for pr in prs if pr.get("merged")]

        return prs

    def save_issues(self, issues: List[Dict[str, Any]]):
        """Save issues as markdown files."""
        existing_files = set()

        for issue in issues:
            state = issue["state"].lower()
            state_dir = self.output_dir / "issues" / state

            filename = self.get_filename(issue["number"], issue["title"], existing_files)
            filepath = state_dir / filename

            markdown = self.generate_issue_markdown(issue)
            self.save_markdown(filepath, markdown)

            self.stats["issues_fetched"] += 1
            self.log(f"Saved issue #{issue['number']}: {filepath}")

    def save_pull_requests(self, prs: List[Dict[str, Any]]):
        """Save pull requests as markdown files."""
        existing_files = set()

        for pr in prs:
            if pr.get("merged"):
                state = "merged"
            else:
                state = pr["state"].lower()

            state_dir = self.output_dir / "pull-requests" / state

            filename = self.get_filename(pr["number"], pr["title"], existing_files)
            filepath = state_dir / filename

            markdown = self.generate_pr_markdown(pr)
            self.save_markdown(filepath, markdown)

            self.stats["prs_fetched"] += 1
            self.log(f"Saved PR #{pr['number']}: {filepath}")

    def generate_metadata(self, issues: List[Dict[str, Any]], prs: List[Dict[str, Any]]):
        """Generate metadata.json with summary information."""
        metadata = {
            "repository": f"{self.owner}/{self.repo}",
            "fetched_at": datetime.utcnow().isoformat() + "Z",
            "stats": {
                "total_issues": len(issues),
                "open_issues": sum(1 for i in issues if i["state"] == "OPEN"),
                "closed_issues": sum(1 for i in issues if i["state"] == "CLOSED"),
                "total_prs": len(prs),
                "open_prs": sum(1 for pr in prs if pr["state"] == "OPEN"),
                "merged_prs": sum(1 for pr in prs if pr.get("merged")),
                "closed_prs": sum(1 for pr in prs if pr["state"] == "CLOSED" and not pr.get("merged")),
                "api_calls_made": self.stats["api_calls"],
            }
        }

        metadata_path = self.output_dir / "metadata.json"
        with open(metadata_path, 'w', encoding='utf-8') as f:
            json.dump(metadata, f, indent=2)

        self.log(f"Generated metadata: {metadata_path}", force=True)

    def run(self, fetch_issues: bool = True, fetch_prs: bool = True, state_filter: str = "all"):
        """
        Run the fetcher.

        Args:
            fetch_issues: Whether to fetch issues
            fetch_prs: Whether to fetch pull requests
            state_filter: Filter by state
        """
        self.log(f"Fetching from {self.owner}/{self.repo}...", force=True)
        self.log(f"Output directory: {self.output_dir}", force=True)

        issues = []
        prs = []

        if fetch_issues:
            self.log("Fetching issues...", force=True)
            issues = self.fetch_issues(state_filter)
            self.log(f"Fetched {len(issues)} issues", force=True)
            self.save_issues(issues)

        if fetch_prs:
            self.log("Fetching pull requests...", force=True)
            prs = self.fetch_pull_requests(state_filter)
            self.log(f"Fetched {len(prs)} pull requests", force=True)
            self.save_pull_requests(prs)

        self.generate_metadata(issues, prs)

        self.log(f"\nCompleted! Stats:", force=True)
        self.log(f"  Issues saved: {self.stats['issues_fetched']}", force=True)
        self.log(f"  PRs saved: {self.stats['prs_fetched']}", force=True)
        self.log(f"  API calls made: {self.stats['api_calls']}", force=True)


def parse_git_remote(remote_url: str) -> tuple:
    """
    Parse git remote URL to extract owner and repo.

    Args:
        remote_url: Git remote URL

    Returns:
        Tuple of (owner, repo)
    """
    # Handle SSH format: git@github.com:owner/repo.git
    if remote_url.startswith("git@"):
        match = re.match(r"git@[^:]+:([^/]+)/(.+?)(?:\.git)?$", remote_url)
        if match:
            return match.group(1), match.group(2)

    # Handle HTTPS format: https://github.com/owner/repo.git
    else:
        parsed = urlparse(remote_url)
        path_parts = parsed.path.strip('/').split('/')
        if len(path_parts) >= 2:
            owner = path_parts[0]
            repo = path_parts[1].replace('.git', '')
            return owner, repo

    raise ValueError(f"Could not parse git remote URL: {remote_url}")


def detect_repo_from_git() -> tuple:
    """
    Detect repository owner and name from git remote.

    Returns:
        Tuple of (owner, repo)
    """
    import subprocess

    try:
        result = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            capture_output=True,
            text=True,
            check=True
        )
        remote_url = result.stdout.strip()
        return parse_git_remote(remote_url)
    except subprocess.CalledProcessError:
        raise ValueError("Not a git repository or no 'origin' remote found")


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Fetch GitHub issues and pull requests as markdown files",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s
  %(prog)s --only-issues
  %(prog)s --state open
  %(prog)s --repo octocat/Hello-World --output ./archive
  %(prog)s --dry-run

Environment variables:
  GITHUB_TOKEN    GitHub personal access token (required)
        """
    )

    parser.add_argument(
        "--output",
        default="./history",
        help="Output directory (default: ./history)"
    )
    parser.add_argument(
        "--repo",
        help="GitHub repository (owner/name). Auto-detected from git remote if not specified."
    )
    parser.add_argument(
        "--token",
        help="GitHub personal access token. Uses GITHUB_TOKEN env var if not specified."
    )
    parser.add_argument(
        "--only-issues",
        action="store_true",
        help="Fetch only issues"
    )
    parser.add_argument(
        "--only-prs",
        action="store_true",
        help="Fetch only pull requests"
    )
    parser.add_argument(
        "--state",
        choices=["all", "open", "closed", "merged"],
        default="all",
        help="Filter by state (default: all)"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be fetched without creating files"
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Enable verbose output"
    )

    args = parser.parse_args()

    # Get token
    token = args.token or os.getenv("GITHUB_TOKEN")
    if not token:
        print("Error: GitHub token required. Set GITHUB_TOKEN environment variable or use --token", file=sys.stderr)
        sys.exit(1)

    # Get repository
    if args.repo:
        try:
            owner, repo = args.repo.split('/', 1)
        except ValueError:
            print(f"Error: Invalid repository format. Expected 'owner/repo', got '{args.repo}'", file=sys.stderr)
            sys.exit(1)
    else:
        try:
            owner, repo = detect_repo_from_git()
            print(f"Detected repository: {owner}/{repo}")
        except ValueError as e:
            print(f"Error: {e}", file=sys.stderr)
            print("Specify repository with --repo owner/repo", file=sys.stderr)
            sys.exit(1)

    # Determine what to fetch
    fetch_issues = not args.only_prs
    fetch_prs = not args.only_issues

    if args.dry_run:
        print(f"Dry run mode - would fetch from {owner}/{repo}")
        print(f"  Output directory: {args.output}")
        print(f"  Fetch issues: {fetch_issues}")
        print(f"  Fetch PRs: {fetch_prs}")
        print(f"  State filter: {args.state}")
        sys.exit(0)

    # Run fetcher
    try:
        fetcher = GitHubHistoryFetcher(
            owner=owner,
            repo=repo,
            token=token,
            output_dir=args.output,
            verbose=args.verbose
        )
        fetcher.run(
            fetch_issues=fetch_issues,
            fetch_prs=fetch_prs,
            state_filter=args.state
        )
    except KeyboardInterrupt:
        print("\nInterrupted by user", file=sys.stderr)
        sys.exit(130)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        if args.verbose:
            import traceback
            traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
