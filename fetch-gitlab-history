#!/usr/bin/env python3
"""
Fetch GitLab issues and merge requests for the repository and save as markdown files.

This tool fetches all issues and merge requests from the GitLab repository,
including their discussions, comments, and reviews, and saves them as
organized markdown files in the history/ directory.
"""

import argparse
import hashlib
import json
import os
import re
import sys
import time
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional, Any
from urllib.parse import urlparse, quote

sys.stdout.reconfigure(line_buffering=True)

try:
    import requests
except ImportError:
    print("Error: 'requests' library is required. Install with: pip install requests", file=sys.stderr)
    sys.exit(1)


class GitLabHistoryFetcher:
    """Fetches and saves GitLab issues and merge requests as markdown files."""

    RATE_LIMIT_THRESHOLD = 100
    MAX_RETRIES = 3
    RETRY_DELAY = 5

    def __init__(self, project_id: str, token: str, gitlab_url: str, output_dir: str, verbose: bool = False):
        """
        Initialize the fetcher.

        Args:
            project_id: Project ID or namespace/project (e.g., 'gitlab-org/gitlab' or '278964')
            token: GitLab personal access token
            gitlab_url: GitLab instance URL (e.g., 'https://gitlab.com')
            output_dir: Directory to save markdown files
            verbose: Enable verbose logging
        """
        self.project_id = quote(project_id, safe='')
        self.token = token
        self.gitlab_url = gitlab_url.rstrip('/')
        self.api_base = f"{self.gitlab_url}/api/v4"
        self.output_dir = Path(output_dir)
        self.verbose = verbose
        self.session = requests.Session()
        self.session.headers.update({
            "PRIVATE-TOKEN": token,
            "Content-Type": "application/json",
        })
        self.stats = {
            "issues_fetched": 0,
            "mrs_fetched": 0,
            "api_calls": 0,
        }

    def log(self, message: str, force: bool = False):
        """Log a message if verbose mode is enabled."""
        if self.verbose or force:
            print(message)

    def check_rate_limit(self):
        """Check GitLab API rate limit from response headers."""
        # GitLab returns rate limit info in response headers
        # We'll check this after each request
        pass

    def api_request(self, endpoint: str, params: Dict[str, Any] = None) -> List[Dict[str, Any]]:
        """
        Make a paginated API request to GitLab.

        Args:
            endpoint: API endpoint (e.g., 'issues')
            params: Query parameters

        Returns:
            List of all items from all pages
        """
        items = []
        page = 1
        per_page = 100

        if params is None:
            params = {}

        params['per_page'] = per_page

        while True:
            params['page'] = page
            url = f"{self.api_base}/projects/{self.project_id}/{endpoint}"

            self.stats["api_calls"] += 1

            for attempt in range(self.MAX_RETRIES):
                try:
                    response = self.session.get(url, params=params)
                    response.raise_for_status()

                    page_items = response.json()
                    items.extend(page_items)

                    # Check if there are more pages
                    if 'x-next-page' in response.headers and response.headers['x-next-page']:
                        page += 1
                        self.log(f"  Fetching page {page} ({len(items)} items so far)...", force=True)
                    else:
                        return items

                    break  # Success, exit retry loop

                except requests.exceptions.RequestException as e:
                    if attempt < self.MAX_RETRIES - 1:
                        wait = self.RETRY_DELAY * (2 ** attempt)
                        self.log(f"Request failed: {e}. Retrying in {wait}s...", force=True)
                        time.sleep(wait)
                    else:
                        raise

        return items

    def sanitize_filename(self, text: str, max_length: int = 50) -> str:
        """
        Sanitize text for use as a filename.

        Args:
            text: Text to sanitize
            max_length: Maximum length of filename

        Returns:
            Sanitized filename
        """
        # Remove or replace invalid characters
        text = re.sub(r'[<>:"/\\|?*]', '', text)
        text = re.sub(r'\s+', '-', text)
        text = text.strip('-').lower()

        # Truncate if too long
        if len(text) > max_length:
            text = text[:max_length].rstrip('-')

        return text or "untitled"

    def get_filename(self, number: int, title: str, existing_files: set) -> str:
        """
        Generate a unique filename for an issue or MR.

        Args:
            number: Issue/MR number
            title: Issue/MR title
            existing_files: Set of existing filenames to avoid conflicts

        Returns:
            Unique filename
        """
        sanitized_title = self.sanitize_filename(title)
        filename = f"{number:04d}-{sanitized_title}.md"

        # Handle conflicts by appending hash
        if filename in existing_files:
            hash_suffix = hashlib.md5(f"{number}{title}".encode()).hexdigest()[:8]
            filename = f"{number:04d}-{sanitized_title}-{hash_suffix}.md"

        existing_files.add(filename)
        return filename

    def format_date(self, date_str: Optional[str]) -> str:
        """Format ISO date string to human-readable format."""
        if not date_str:
            return "N/A"
        try:
            dt = datetime.fromisoformat(date_str.replace('Z', '+00:00'))
            return dt.strftime("%B %d, %Y at %I:%M %p UTC")
        except (ValueError, AttributeError):
            return date_str or "N/A"

    def fetch_issue_notes(self, issue_iid: int) -> List[Dict[str, Any]]:
        """Fetch notes (comments) for an issue."""
        endpoint = f"issues/{issue_iid}/notes"
        return self.api_request(endpoint)

    def fetch_mr_notes(self, mr_iid: int) -> List[Dict[str, Any]]:
        """Fetch notes (comments) for a merge request."""
        endpoint = f"merge_requests/{mr_iid}/notes"
        return self.api_request(endpoint)

    def generate_issue_markdown(self, issue: Dict[str, Any], notes: List[Dict[str, Any]]) -> str:
        """
        Generate markdown content for an issue.

        Args:
            issue: Issue data from GitLab API
            notes: Notes/comments on the issue

        Returns:
            Markdown content
        """
        author = issue.get("author", {})
        author_username = author.get("username", "[deleted]") if author else "[deleted]"

        labels = issue.get("labels", [])
        labels_str = ", ".join(f"`{label}`" for label in labels) if labels else "None"

        url = issue.get("web_url", "")

        markdown = f"""---
type: issue
number: {issue['iid']}
title: {json.dumps(issue['title'])}
state: {issue['state']}
author: {author_username}
created: {issue['created_at']}
updated: {issue['updated_at']}
"""

        if issue.get('closed_at'):
            markdown += f"closed: {issue['closed_at']}\n"

        markdown += f"""labels: {json.dumps(labels)}
url: {url}
---

# Issue #{issue['iid']}: {issue['title']}

**Author**: @{author_username}
**Created**: {self.format_date(issue['created_at'])}
**Status**: {issue['state'].title()}
**Labels**: {labels_str}

## Description

{issue.get('description', '') or '*No description provided*'}

"""

        # Add comments/notes
        if notes:
            markdown += "---\n\n## Discussion\n\n"
            for note in notes:
                # Skip system notes
                if note.get('system'):
                    continue

                note_author = note.get("author", {})
                note_author_username = note_author.get("username", "[deleted]") if note_author else "[deleted]"
                markdown += f"### Comment by @{note_author_username} on {self.format_date(note['created_at'])}\n\n"
                markdown += f"{note.get('body', '')}\n\n"

        markdown += f"---\n\n*Archived from: {url}*\n"

        return markdown

    def generate_mr_markdown(self, mr: Dict[str, Any], notes: List[Dict[str, Any]]) -> str:
        """
        Generate markdown content for a merge request.

        Args:
            mr: Merge request data from GitLab API
            notes: Notes/comments on the MR

        Returns:
            Markdown content
        """
        author = mr.get("author", {})
        author_username = author.get("username", "[deleted]") if author else "[deleted]"

        labels = mr.get("labels", [])
        labels_str = ", ".join(f"`{label}`" for label in labels) if labels else "None"

        state = "merged" if mr.get("merged_at") else mr["state"]
        url = mr.get("web_url", "")

        markdown = f"""---
type: merge_request
number: {mr['iid']}
title: {json.dumps(mr['title'])}
state: {state}
author: {author_username}
created: {mr['created_at']}
updated: {mr['updated_at']}
"""

        if mr.get('closed_at'):
            markdown += f"closed: {mr['closed_at']}\n"
        if mr.get('merged_at'):
            markdown += f"merged: {mr['merged_at']}\n"

        markdown += f"""target_branch: {mr.get('target_branch', 'N/A')}
source_branch: {mr.get('source_branch', 'N/A')}
labels: {json.dumps(labels)}
url: {url}
---

# Merge Request !{mr['iid']}: {mr['title']}

**Author**: @{author_username}
**Created**: {self.format_date(mr['created_at'])}
**Status**: {state.title()}
**Labels**: {labels_str}
**Target**: `{mr.get('target_branch', 'N/A')}` ← **Source**: `{mr.get('source_branch', 'N/A')}`

## Description

{mr.get('description', '') or '*No description provided*'}

"""

        # Add comments/notes (filter out system notes and reviews)
        discussion_notes = [n for n in notes if not n.get('system')]

        if discussion_notes:
            markdown += "---\n\n## Discussion\n\n"
            for note in discussion_notes:
                note_author = note.get("author", {})
                note_author_username = note_author.get("username", "[deleted]") if note_author else "[deleted]"
                markdown += f"### Comment by @{note_author_username} on {self.format_date(note['created_at'])}\n\n"
                if note.get('body'):
                    markdown += f"{note['body']}\n\n"

        markdown += f"---\n\n*Archived from: {url}*\n"

        return markdown

    def save_markdown(self, filepath: Path, content: str):
        """Save markdown content to file."""
        filepath.parent.mkdir(parents=True, exist_ok=True)
        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(content)

    def fetch_issues(self, state_filter: str = "all") -> List[Dict[str, Any]]:
        """
        Fetch all issues.

        Args:
            state_filter: Filter by state ('all', 'opened', 'closed')

        Returns:
            List of issue data
        """
        params = {}
        if state_filter != "all":
            params['state'] = state_filter

        self.log("Fetching issues...", force=True)
        issues = self.api_request("issues", params)
        self.log(f"Fetched {len(issues)} issues", force=True)

        return issues

    def fetch_merge_requests(self, state_filter: str = "all") -> List[Dict[str, Any]]:
        """
        Fetch all merge requests.

        Args:
            state_filter: Filter by state ('all', 'opened', 'closed', 'merged')

        Returns:
            List of merge request data
        """
        params = {}
        if state_filter in ["opened", "closed", "merged"]:
            params['state'] = state_filter

        self.log("Fetching merge requests...", force=True)
        mrs = self.api_request("merge_requests", params)
        self.log(f"Fetched {len(mrs)} merge requests", force=True)

        return mrs

    def save_issues(self, issues: List[Dict[str, Any]]):
        """Save issues as markdown files."""
        existing_files = set()
        total = len(issues)
        self.log(f"Saving {total} issues (fetching notes for each)...", force=True)

        for idx, issue in enumerate(issues, 1):
            state = issue["state"].lower()
            state_dir = self.output_dir / "issues" / state

            filename = self.get_filename(issue["iid"], issue["title"], existing_files)
            filepath = state_dir / filename

            # Fetch notes for this issue
            notes = self.fetch_issue_notes(issue["iid"])

            markdown = self.generate_issue_markdown(issue, notes)
            self.save_markdown(filepath, markdown)

            self.stats["issues_fetched"] += 1
            self.log(f"Saved issue #{issue['iid']}: {filepath}")
            if idx % 10 == 0 or idx == total:
                self.log(f"  Issues: {idx}/{total} saved", force=True)

    def save_merge_requests(self, mrs: List[Dict[str, Any]]):
        """Save merge requests as markdown files."""
        existing_files = set()
        total = len(mrs)
        self.log(f"Saving {total} merge requests (fetching notes for each)...", force=True)

        for idx, mr in enumerate(mrs, 1):
            if mr.get("merged_at"):
                state = "merged"
            else:
                state = mr["state"].lower()

            state_dir = self.output_dir / "merge-requests" / state

            filename = self.get_filename(mr["iid"], mr["title"], existing_files)
            filepath = state_dir / filename

            # Fetch notes for this MR
            notes = self.fetch_mr_notes(mr["iid"])

            markdown = self.generate_mr_markdown(mr, notes)
            self.save_markdown(filepath, markdown)

            self.stats["mrs_fetched"] += 1
            self.log(f"Saved MR !{mr['iid']}: {filepath}")
            if idx % 10 == 0 or idx == total:
                self.log(f"  MRs: {idx}/{total} saved", force=True)

    def generate_metadata(self, issues: List[Dict[str, Any]], mrs: List[Dict[str, Any]]):
        """Generate metadata.json with summary information."""
        metadata = {
            "project_id": self.project_id,
            "gitlab_url": self.gitlab_url,
            "fetched_at": datetime.utcnow().isoformat() + "Z",
            "stats": {
                "total_issues": len(issues),
                "opened_issues": sum(1 for i in issues if i["state"] == "opened"),
                "closed_issues": sum(1 for i in issues if i["state"] == "closed"),
                "total_mrs": len(mrs),
                "opened_mrs": sum(1 for mr in mrs if mr["state"] == "opened"),
                "merged_mrs": sum(1 for mr in mrs if mr.get("merged_at")),
                "closed_mrs": sum(1 for mr in mrs if mr["state"] == "closed" and not mr.get("merged_at")),
                "api_calls_made": self.stats["api_calls"],
            }
        }

        metadata_path = self.output_dir / "metadata-gitlab.json"
        with open(metadata_path, 'w', encoding='utf-8') as f:
            json.dump(metadata, f, indent=2)

        self.log(f"Generated metadata: {metadata_path}", force=True)

    def run(self, fetch_issues: bool = True, fetch_mrs: bool = True, state_filter: str = "all"):
        """
        Run the fetcher.

        Args:
            fetch_issues: Whether to fetch issues
            fetch_mrs: Whether to fetch merge requests
            state_filter: Filter by state
        """
        self.log(f"Fetching from GitLab project: {self.project_id}", force=True)
        self.log(f"GitLab URL: {self.gitlab_url}", force=True)
        self.log(f"Output directory: {self.output_dir}", force=True)

        issues = []
        mrs = []

        if fetch_issues:
            issues = self.fetch_issues(state_filter)
            self.save_issues(issues)

        if fetch_mrs:
            mrs = self.fetch_merge_requests(state_filter)
            self.save_merge_requests(mrs)

        self.generate_metadata(issues, mrs)

        self.log(f"\nCompleted! Stats:", force=True)
        self.log(f"  Issues saved: {self.stats['issues_fetched']}", force=True)
        self.log(f"  MRs saved: {self.stats['mrs_fetched']}", force=True)
        self.log(f"  API calls made: {self.stats['api_calls']}", force=True)


def parse_git_remote(remote_url: str) -> tuple:
    """
    Parse git remote URL to extract project path and GitLab URL.

    Args:
        remote_url: Git remote URL

    Returns:
        Tuple of (gitlab_url, project_path)
    """
    # Handle SSH format: git@gitlab.com:namespace/project.git
    if remote_url.startswith("git@"):
        match = re.match(r"git@([^:]+):(.+?)(?:\.git)?$", remote_url)
        if match:
            host = match.group(1)
            project_path = match.group(2)
            gitlab_url = f"https://{host}"
            return gitlab_url, project_path

    # Handle HTTPS format: https://gitlab.com/namespace/project.git
    else:
        parsed = urlparse(remote_url)
        gitlab_url = f"{parsed.scheme}://{parsed.netloc}"
        project_path = parsed.path.strip('/').replace('.git', '')
        return gitlab_url, project_path

    raise ValueError(f"Could not parse git remote URL: {remote_url}")


def detect_repo_from_git() -> tuple:
    """
    Detect GitLab project from git remote.

    Returns:
        Tuple of (gitlab_url, project_path)
    """
    import subprocess

    try:
        result = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            capture_output=True,
            text=True,
            check=True
        )
        remote_url = result.stdout.strip()

        # Check if it's a GitLab URL
        if 'gitlab' not in remote_url.lower():
            raise ValueError("Remote does not appear to be a GitLab repository")

        return parse_git_remote(remote_url)
    except subprocess.CalledProcessError:
        raise ValueError("Not a git repository or no 'origin' remote found")


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Fetch GitLab issues and merge requests as markdown files",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s
  %(prog)s --only-issues
  %(prog)s --state opened
  %(prog)s --project gitlab-org/gitlab --output ./archive
  %(prog)s --dry-run

Environment variables:
  GITLAB_TOKEN    GitLab personal access token (required)
  GITLAB_URL      GitLab instance URL (default: https://gitlab.com)
        """
    )

    parser.add_argument(
        "--output",
        default="./history",
        help="Output directory (default: ./history)"
    )
    parser.add_argument(
        "--project",
        help="GitLab project (namespace/project or project ID). Auto-detected from git remote if not specified."
    )
    parser.add_argument(
        "--gitlab-url",
        help="GitLab instance URL (default: from git remote or https://gitlab.com). Can also use GITLAB_URL env var."
    )
    parser.add_argument(
        "--token",
        help="GitLab personal access token. Uses GITLAB_TOKEN env var if not specified."
    )
    parser.add_argument(
        "--only-issues",
        action="store_true",
        help="Fetch only issues"
    )
    parser.add_argument(
        "--only-mrs",
        action="store_true",
        help="Fetch only merge requests"
    )
    parser.add_argument(
        "--state",
        choices=["all", "opened", "closed", "merged"],
        default="all",
        help="Filter by state (default: all)"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be fetched without creating files"
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Enable verbose output"
    )

    args = parser.parse_args()

    # Get token
    token = args.token or os.getenv("GITLAB_TOKEN")
    if not token:
        print("Error: GitLab token required. Set GITLAB_TOKEN environment variable or use --token", file=sys.stderr)
        sys.exit(1)

    # Get GitLab URL and project
    gitlab_url = args.gitlab_url or os.getenv("GITLAB_URL")

    if args.project:
        project_id = args.project
        if not gitlab_url:
            gitlab_url = "https://gitlab.com"
    else:
        try:
            detected_url, detected_project = detect_repo_from_git()
            project_id = detected_project
            if not gitlab_url:
                gitlab_url = detected_url
            print(f"Detected GitLab project: {project_id}")
            print(f"Detected GitLab URL: {gitlab_url}")
        except ValueError as e:
            print(f"Error: {e}", file=sys.stderr)
            print("Specify project with --project namespace/project", file=sys.stderr)
            sys.exit(1)

    # Determine what to fetch
    fetch_issues = not args.only_mrs
    fetch_mrs = not args.only_issues

    if args.dry_run:
        print(f"Dry run mode - would fetch from {project_id}")
        print(f"  GitLab URL: {gitlab_url}")
        print(f"  Output directory: {args.output}")
        print(f"  Fetch issues: {fetch_issues}")
        print(f"  Fetch MRs: {fetch_mrs}")
        print(f"  State filter: {args.state}")
        sys.exit(0)

    # Run fetcher
    try:
        fetcher = GitLabHistoryFetcher(
            project_id=project_id,
            token=token,
            gitlab_url=gitlab_url,
            output_dir=args.output,
            verbose=args.verbose
        )
        fetcher.run(
            fetch_issues=fetch_issues,
            fetch_mrs=fetch_mrs,
            state_filter=args.state
        )
    except KeyboardInterrupt:
        print("\nInterrupted by user", file=sys.stderr)
        sys.exit(130)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        if args.verbose:
            import traceback
            traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
