#!/usr/bin/env python3
"""
Interactive setup for project history generation.

This script configures the project for history generation by asking
about Git hosting platform (GitHub/GitLab) and optional Jira integration.
"""

import json
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import Dict, List, Optional, Tuple
from urllib.parse import urlparse


def print_header(text: str):
    """Print a formatted header."""
    print(f"\n{'=' * 70}")
    print(f"  {text}")
    print(f"{'=' * 70}\n")


def print_info(text: str):
    """Print an info message."""
    print(f"ℹ️  {text}")


def print_success(text: str):
    """Print a success message."""
    print(f"✓ {text}")


def print_error(text: str):
    """Print an error message."""
    print(f"✗ {text}", file=sys.stderr)


def get_input(prompt: str, default: Optional[str] = None) -> str:
    """Get user input with optional default value."""
    if default:
        response = input(f"{prompt} [{default}]: ").strip()
        return response if response else default
    else:
        while True:
            response = input(f"{prompt}: ").strip()
            if response:
                return response
            print("  This field is required. Please enter a value.")


def get_yes_no(prompt: str, default: bool = False) -> bool:
    """Get yes/no input from user."""
    default_str = "Y/n" if default else "y/N"
    while True:
        response = input(f"{prompt} [{default_str}]: ").strip().lower()
        if not response:
            return default
        if response in ['y', 'yes']:
            return True
        if response in ['n', 'no']:
            return False
        print("  Please enter 'y' or 'n'")


def _find_git_root(path: str) -> Optional[str]:
    """
    Find the git repo root at the given path or its immediate parent.

    Only checks the directory itself and one level up (for the tools/
    subdirectory case). Does not walk further to avoid detecting
    unrelated ancestor repos.
    """
    p = Path(path).resolve()
    if (p / '.git').is_dir():
        return str(p)
    parent = p.parent
    if (parent / '.git').is_dir():
        return str(parent)
    return None


def detect_git_remote(cwd: Optional[str] = None) -> Optional[Tuple[str, str, str]]:
    """
    Detect Git hosting platform from remote URL.

    Only checks the given directory and its immediate parent for a .git/
    directory, to avoid false detection from distant ancestor repos when
    git walks up the directory tree.

    Args:
        cwd: Directory to check (defaults to current directory)

    Returns:
        Tuple of (platform, url, project_path) or None
    """
    check_dir = cwd or os.getcwd()

    # Only detect if this directory or its immediate parent is a git repo.
    # Without this check, git walks up the full directory tree and may
    # detect an unrelated ancestor repo.
    git_root = _find_git_root(check_dir)
    if not git_root:
        return None

    try:
        result = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            capture_output=True,
            text=True,
            check=True,
            cwd=check_dir
        )
        remote_url = result.stdout.strip()

        # Detect GitHub
        if 'github.com' in remote_url:
            owner, repo = parse_github_remote(remote_url)
            return ('github', 'https://github.com', f"{owner}/{repo}")

        # Detect GitLab
        if 'gitlab' in remote_url:
            gitlab_url, project_path = parse_gitlab_remote(remote_url)
            return ('gitlab', gitlab_url, project_path)

        return None

    except (subprocess.CalledProcessError, ValueError):
        return None


def detect_nearby_repos(project_root: Path = None) -> List[Dict]:
    """
    Scan for git repositories in subdirectories of the project root.

    Args:
        project_root: The project root directory to search. Defaults to CWD.

    Returns:
        List of dicts with keys: path, name, platform, platform_info
    """
    repos = []
    seen_paths = set()

    if project_root is None:
        project_root = Path('.')

    for search_root in [project_root]:
        if not search_root.is_dir():
            continue

        for entry in sorted(search_root.iterdir()):
            if not entry.is_dir() or not (entry / '.git').is_dir():
                continue

            real_path = entry.resolve()
            if real_path in seen_paths:
                continue
            seen_paths.add(real_path)

            repo_info = {
                'path': str(real_path),
                'name': entry.name,
                'platform': None,
                'platform_info': {}
            }

            detected = detect_git_remote(cwd=str(entry))
            if detected:
                platform, url, project_path = detected
                repo_info['platform'] = platform
                if platform == 'github':
                    owner, repo = project_path.split('/', 1)
                    repo_info['platform_info'] = {'owner': owner, 'repo': repo}
                elif platform == 'gitlab':
                    repo_info['platform_info'] = {'project_id': project_path, 'url': url}

            repos.append(repo_info)

    return repos


def parse_github_remote(remote_url: str) -> Tuple[str, str]:
    """Parse GitHub remote URL to extract owner and repo."""
    # SSH: git@github.com:owner/repo.git
    if remote_url.startswith("git@"):
        match = re.match(r"git@[^:]+:([^/]+)/(.+?)(?:\.git)?$", remote_url)
        if match:
            return match.group(1), match.group(2)

    # HTTPS: https://github.com/owner/repo.git
    parsed = urlparse(remote_url)
    path_parts = parsed.path.strip('/').split('/')
    if len(path_parts) >= 2:
        owner = path_parts[0]
        repo = path_parts[1].replace('.git', '')
        return owner, repo

    raise ValueError(f"Could not parse GitHub URL: {remote_url}")


def parse_gitlab_remote(remote_url: str) -> Tuple[str, str]:
    """Parse GitLab remote URL to extract URL and project path."""
    # SSH: git@gitlab.com:namespace/project.git
    if remote_url.startswith("git@"):
        match = re.match(r"git@([^:]+):(.+?)(?:\.git)?$", remote_url)
        if match:
            host = match.group(1)
            project_path = match.group(2)
            gitlab_url = f"https://{host}"
            return gitlab_url, project_path

    # HTTPS: https://gitlab.com/namespace/project.git
    parsed = urlparse(remote_url)
    gitlab_url = f"{parsed.scheme}://{parsed.netloc}"
    project_path = parsed.path.strip('/').replace('.git', '')
    return gitlab_url, project_path


def configure_github(detected: Optional[Tuple[str, str, str]] = None) -> Dict:
    """Configure GitHub settings."""
    print_header("GitHub Configuration")

    if not detected:
        detected = detect_git_remote()
    if detected and detected[0] == 'github':
        print_info(f"Detected GitHub repository: {detected[2]}")
        use_detected = get_yes_no("Use detected repository?", default=True)

        if use_detected:
            owner, repo = detected[2].split('/')
            return {
                'enabled': True,
                'owner': owner,
                'repo': repo
            }

    print_info("Enter GitHub repository details (owner/repo format)")
    repo_full = get_input("Repository (e.g., 'octocat/Hello-World')")

    try:
        owner, repo = repo_full.split('/', 1)
        return {
            'enabled': True,
            'owner': owner.strip(),
            'repo': repo.strip()
        }
    except ValueError:
        print_error("Invalid format. Expected 'owner/repo'")
        sys.exit(1)


def configure_gitlab(detected: Optional[Tuple[str, str, str]] = None) -> Dict:
    """Configure GitLab settings."""
    print_header("GitLab Configuration")

    if not detected:
        detected = detect_git_remote()
    if detected and detected[0] == 'gitlab':
        print_info(f"Detected GitLab repository: {detected[2]}")
        print_info(f"GitLab URL: {detected[1]}")
        use_detected = get_yes_no("Use detected repository?", default=True)

        if use_detected:
            return {
                'enabled': True,
                'project_id': detected[2],
                'url': detected[1]
            }

    print_info("Enter GitLab instance and project details")
    gitlab_url = get_input("GitLab URL (e.g., 'https://gitlab.com')", default="https://gitlab.com")
    project_id = get_input("Project path (e.g., 'namespace/project')")

    return {
        'enabled': True,
        'project_id': project_id.strip(),
        'url': gitlab_url.strip().rstrip('/')
    }


def configure_jira() -> Dict:
    """Configure Jira settings."""
    print_header("Jira Configuration")

    print_info("Jira integration is optional but recommended for complete history")
    enable_jira = get_yes_no("Enable Jira integration?", default=False)

    if not enable_jira:
        return {'enabled': False}

    jira_url = get_input("Jira URL (e.g., 'https://mycompany.atlassian.net')")

    projects = []
    while True:
        project_key = get_input("Jira project key (e.g., 'PROJ')")
        projects.append({'project_key': project_key.strip().upper()})

        if not get_yes_no("Add another Jira project?", default=False):
            break

    print_info("JQL filters can be configured later during the history generation workflow")

    return {
        'enabled': True,
        'url': jira_url.strip().rstrip('/'),
        'projects': projects
    }


def configure_repo(repo_info: Dict, index: int, total: int) -> Dict:
    """
    Configure a single repository in multi-repo mode.

    Args:
        repo_info: Detected repo info (path, platform, platform_info)
        index: 1-based index of this repo
        total: Total number of repos being configured

    Returns:
        Repo configuration dict
    """
    print(f"\n--- Repository {index} of {total} ---")
    print(f"  Path: {repo_info['path']}")

    repo_config = {
        'name': repo_info['name'],
        'local_path': repo_info['path'],
    }

    # Use detected platform or ask
    if repo_info['platform']:
        platform = repo_info['platform']
        info = repo_info['platform_info']

        if platform == 'github':
            print_info(f"Detected GitHub repository: {info['owner']}/{info['repo']}")
            use_detected = get_yes_no("Use detected repository?", default=True)
            if use_detected:
                repo_config['platform'] = 'github'
                repo_config['owner'] = info['owner']
                repo_config['repo'] = info['repo']
            else:
                repo_config.update(_ask_platform_details())
        elif platform == 'gitlab':
            print_info(f"Detected GitLab repository: {info['project_id']}")
            print_info(f"GitLab URL: {info['url']}")
            use_detected = get_yes_no("Use detected repository?", default=True)
            if use_detected:
                repo_config['platform'] = 'gitlab'
                repo_config['project_id'] = info['project_id']
                repo_config['url'] = info['url']
            else:
                repo_config.update(_ask_platform_details())
    else:
        print_info("Could not detect git platform for this repository")
        repo_config.update(_ask_platform_details())

    # Allow overriding the name
    repo_config['name'] = get_input("Repository name", default=repo_config['name'])

    return repo_config


def _ask_platform_details() -> Dict:
    """Ask user for platform details manually."""
    print("  Which platform hosts this repository?")
    print("    1. GitHub")
    print("    2. GitLab")

    while True:
        choice = input("  Choice [1/2]: ").strip()
        if choice == '1':
            repo_full = get_input("  Repository (e.g., 'owner/repo')")
            try:
                owner, repo = repo_full.split('/', 1)
                return {
                    'platform': 'github',
                    'owner': owner.strip(),
                    'repo': repo.strip()
                }
            except ValueError:
                print_error("Invalid format. Expected 'owner/repo'")
                sys.exit(1)
        elif choice == '2':
            gitlab_url = get_input("  GitLab URL", default="https://gitlab.com")
            project_id = get_input("  Project path (e.g., 'namespace/project')")
            return {
                'platform': 'gitlab',
                'project_id': project_id.strip(),
                'url': gitlab_url.strip().rstrip('/')
            }
        else:
            print("  Please enter 1 or 2")


def check_environment_variables(config: Dict) -> bool:
    """Check if required environment variables are set."""
    print_header("Environment Variables Check")

    all_set = True
    recommendations = []

    # Determine which platforms are in use
    needs_github = False
    needs_gitlab = False

    if 'repos' in config:
        for repo in config['repos']:
            if repo['platform'] == 'github':
                needs_github = True
            elif repo['platform'] == 'gitlab':
                needs_gitlab = True
    else:
        needs_github = config['platforms']['github'].get('enabled', False)
        needs_gitlab = config['platforms']['gitlab'].get('enabled', False)

    needs_jira = config.get('platforms', {}).get('jira', {}).get('enabled', False)

    if needs_github:
        if not os.getenv('GITHUB_TOKEN'):
            print_error("GITHUB_TOKEN not set")
            recommendations.append("export GITHUB_TOKEN='ghp_...'  # Create at https://github.com/settings/tokens")
            all_set = False
        else:
            print_success("GITHUB_TOKEN is set")

    if needs_gitlab:
        if not os.getenv('GITLAB_TOKEN'):
            print_error("GITLAB_TOKEN not set")
            recommendations.append("export GITLAB_TOKEN='glpat-...'  # Create in GitLab Settings → Access Tokens")
            all_set = False
        else:
            print_success("GITLAB_TOKEN is set")

    if needs_jira:
        if not os.getenv('JIRA_TOKEN'):
            print_error("JIRA_TOKEN not set")
            recommendations.append("export JIRA_TOKEN='...'  # Create in Jira Account Settings → Security → API Tokens")
            all_set = False
        else:
            print_success("JIRA_TOKEN is set")

    if not all_set:
        print("\n📝 To set environment variables, run:\n")
        for rec in recommendations:
            print(f"  {rec}")
        print("\n⚠️  These tokens are required before fetching history data.")

    return all_set


def save_config(config: Dict, config_file: Path):
    """Save configuration to file."""
    with open(config_file, 'w') as f:
        json.dump(config, f, indent=2)
    print_success(f"Configuration saved to {config_file}")


def display_next_steps(config: Dict):
    """Display next steps for the user."""
    print_header("Next Steps")

    print("1. Set environment variables for authentication (if not already set)")
    print()

    # Determine which platforms need tokens
    needs_github = False
    needs_gitlab = False

    if 'repos' in config:
        for repo in config['repos']:
            if repo['platform'] == 'github':
                needs_github = True
            elif repo['platform'] == 'gitlab':
                needs_gitlab = True
    else:
        needs_github = config['platforms']['github'].get('enabled', False)
        needs_gitlab = config['platforms']['gitlab'].get('enabled', False)

    needs_jira = config.get('platforms', {}).get('jira', {}).get('enabled', False)

    if needs_github:
        print("   GitHub:")
        print("     export GITHUB_TOKEN='your_token_here'")
        print("     Get token at: https://github.com/settings/tokens (needs 'repo' scope)")
        print()

    if needs_gitlab:
        print("   GitLab:")
        print("     export GITLAB_TOKEN='your_token_here'")
        print("     Get token in GitLab Settings → Access Tokens (needs 'read_api' scope)")
        print()

    if needs_jira:
        print("   Jira:")
        print("     export JIRA_TOKEN='your_token_here'")
        jira_url = config['platforms']['jira']['url']
        print(f"     Get token at: {jira_url}/secure/ViewProfile.jspa (API Tokens)")
        print()

    script_dir = Path(__file__).parent.resolve()
    if script_dir.name == 'tools':
        cmd_prefix = './tools/'
    else:
        cmd_prefix = './'

    print("2. Fetch history data:")
    print(f"     {cmd_prefix}fetch-history")
    print()

    print("3. Generate timeline and analysis:")
    print(f"     {cmd_prefix}generate-history-draft")
    print()

    print("4. Follow the AI-assisted curation workflow:")
    print(f"     See {cmd_prefix}HISTORY_GENERATION_GUIDE.md for detailed prompts")
    print()


def main():
    """Main entry point."""
    print_header("Project History Generator - Setup")

    print("This wizard will configure project history generation for your repository.")
    print("You'll be asked about Git hosting (GitHub/GitLab) and optional Jira integration.")
    print()

    script_dir = Path(__file__).parent.resolve()
    if script_dir.name == 'tools':
        project_root = script_dir.parent
    else:
        project_root = Path.cwd()
    config_file = project_root / ".project-history-config.json"

    # Check if config already exists
    if config_file.exists():
        print_info(f"Configuration file already exists: {config_file}")
        overwrite = get_yes_no("Overwrite existing configuration?", default=False)
        if not overwrite:
            print("Setup cancelled.")
            sys.exit(0)

    # Detect environment: is CWD a git repo? Are there nearby repos?
    detected = detect_git_remote()
    nearby_repos = detect_nearby_repos(project_root)

    multi_repo = False

    if nearby_repos:
        print_info(f"Detected {len(nearby_repos)} git repositor{'y' if len(nearby_repos) == 1 else 'ies'}:")
        for repo_info in nearby_repos:
            platform_desc = ""
            if repo_info['platform'] == 'github':
                info = repo_info['platform_info']
                platform_desc = f" (GitHub: {info['owner']}/{info['repo']})"
            elif repo_info['platform'] == 'gitlab':
                info = repo_info['platform_info']
                platform_desc = f" (GitLab: {info['project_id']})"
            print(f"    {repo_info['path']}{platform_desc}")
        print()

        if len(nearby_repos) > 1:
            multi_repo = get_yes_no("Configure as a multi-repository project?", default=True)
        elif not detected:
            multi_repo = get_yes_no("Configure as a multi-repository project?", default=False)
    elif detected:
        platform, url, project = detected
        print_info(f"Detected {platform.title()} repository from git remote")

    if multi_repo:
        _setup_multi_repo(config_file, nearby_repos)
    else:
        if not detected and len(nearby_repos) == 1:
            repo = nearby_repos[0]
            if repo['platform'] and repo['platform_info']:
                info = repo['platform_info']
                if repo['platform'] == 'github':
                    detected = ('github', 'https://github.com',
                                f"{info['owner']}/{info['repo']}")
                elif repo['platform'] == 'gitlab':
                    detected = ('gitlab', info['url'], info['project_id'])
        _setup_single_repo(config_file, detected)


def _setup_single_repo(config_file: Path, detected: Optional[Tuple[str, str, str]]):
    """Run the single-repository setup flow (original behavior)."""
    # Ask which platforms to configure
    print_header("Platform Selection")
    print("Which platforms does your project use?")
    print()

    use_github = get_yes_no("GitHub?", default=(detected and detected[0] == 'github'))
    use_gitlab = get_yes_no("GitLab?", default=(detected and detected[0] == 'gitlab'))

    if not use_github and not use_gitlab:
        print_error("At least one Git platform (GitHub or GitLab) must be enabled")
        sys.exit(1)

    # Configure platforms
    config = {
        'platforms': {
            'github': {'enabled': False},
            'gitlab': {'enabled': False},
            'jira': {'enabled': False}
        },
        'output_dir': './history'
    }

    if use_github:
        config['platforms']['github'] = configure_github(detected)

    if use_gitlab:
        config['platforms']['gitlab'] = configure_gitlab(detected)

    # Always ask about Jira
    config['platforms']['jira'] = configure_jira()

    # Output directory
    print_header("Output Directory")
    output_dir = get_input("Where should history files be saved?", default="./history")
    config['output_dir'] = output_dir

    # Save configuration
    save_config(config, config_file)

    # Check environment variables
    check_environment_variables(config)

    # Display next steps
    display_next_steps(config)

    print_success("Setup complete!")


def _setup_multi_repo(config_file: Path, detected_repos: List[Dict]):
    """Run the multi-repository setup flow."""
    print_header("Multi-Repository Configuration")

    print("Configure each repository that is part of this project.")
    print("You can add additional repositories beyond those auto-detected.")
    print()

    # First, ask which detected repos to include
    included_repos = []
    for repo_info in detected_repos:
        include = get_yes_no(f"Include {repo_info['path']}?", default=True)
        if include:
            included_repos.append(repo_info)

    # Allow adding more repos manually
    while get_yes_no("\nAdd another repository?", default=False):
        path = get_input("  Local path to repository")
        if not Path(path).is_dir():
            print_error(f"Directory not found: {path}")
            continue

        repo_info = {
            'path': path,
            'name': Path(path).name,
            'platform': None,
            'platform_info': {}
        }

        repo_detected = detect_git_remote(cwd=path)
        if repo_detected:
            platform, url, project_path = repo_detected
            repo_info['platform'] = platform
            if platform == 'github':
                owner, repo = project_path.split('/', 1)
                repo_info['platform_info'] = {'owner': owner, 'repo': repo}
            elif platform == 'gitlab':
                repo_info['platform_info'] = {'project_id': project_path, 'url': url}

        included_repos.append(repo_info)

    if not included_repos:
        print_error("At least one repository must be configured")
        sys.exit(1)

    # Now configure each included repo with correct numbering
    total = len(included_repos)
    repos = []
    for i, repo_info in enumerate(included_repos, 1):
        repo_config = configure_repo(repo_info, i, total)
        repos.append(repo_config)

    if not repos:
        print_error("At least one repository must be configured")
        sys.exit(1)

    print(f"\n  Configured {len(repos)} repositor{'y' if len(repos) == 1 else 'ies'}:")
    for repo in repos:
        project_desc = repo.get('project_id') or f"{repo.get('owner')}/{repo.get('repo')}"
        print(f"    • {repo['name']} ({repo['platform'].title()}: {project_desc})")

    # Jira (shared across all repos)
    jira_config = configure_jira()

    # Output directory
    print_header("Output Directory")
    output_dir = get_input("Where should history files be saved?", default="./history")

    # Build config
    config = {
        'repos': repos,
        'platforms': {
            'jira': jira_config
        },
        'output_dir': output_dir
    }

    # Save configuration
    save_config(config, config_file)

    # Check environment variables
    check_environment_variables(config)

    # Display next steps
    display_next_steps(config)

    print_success("Setup complete!")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\nSetup cancelled by user")
        sys.exit(130)
    except Exception as e:
        print_error(f"Setup failed: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
